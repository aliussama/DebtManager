<Window x:Class="DebtManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DebtManager" Height="900" Width="1350"
        Background="#0F0F10">

    <Window.Resources>

        <!-- Common brushes -->
        <SolidColorBrush x:Key="BgWindow" Color="#0F0F10"/>
        <SolidColorBrush x:Key="BgPanel" Color="#17171A"/>
        <SolidColorBrush x:Key="BgAlt" Color="#101013"/>
        <SolidColorBrush x:Key="FgMain" Color="#EAEAEA"/>
        <SolidColorBrush x:Key="FgSub" Color="#D6D6D8"/>
        <SolidColorBrush x:Key="GridLine" Color="#2A2A2E"/>

        <!-- DataGrid dark theme -->
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPanel}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgAlt}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLine}"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="12">

        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#17171A"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Create Tuition" Width="140" Margin="0,0,10,0" Click="Create_Click"/>
                    <Button Content="Define Schedule" Width="140" Margin="0,0,10,0" Click="Schedule_Click"/>
                    <Button Content="Record 12k" Width="120" Margin="0,0,10,0" Click="Pay_Click"/>
                    <Button Content="Install Rule Pack" Width="150" Margin="0,0,10,0" Click="InstallRules_Click"/>
                    <Button Content="Simulate +5k" Width="140" Margin="0,0,10,0" Click="Simulate_Click"/>
                    <Button Content="Snapshot (End 2026)" Width="170" Margin="0,0,10,0" Click="Snapshot_Click"/>
                    <Button Content="Export Audit CSV" Width="150" Click="ExportAudit_Click"/>
                </StackPanel>

                <TextBlock x:Name="SummaryText"
                           Foreground="#D6D6D8"
                           FontSize="14"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top: Installments + Crisis -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#17171A" CornerRadius="10" Padding="10" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Installments"
                                   Foreground="#EAEAEA"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,8"/>
                        <DataGrid x:Name="InstallmentsGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="#17171A"
                                  Foreground="#EAEAEA"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="#17171A" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Portfolio Crisis Status"
                                   Foreground="#EAEAEA"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,8"/>

                        <Border Background="#101013" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                            <TextBlock Text="{Binding PortfolioStatus.BannerText}"
                                       Foreground="#D6D6D8"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <DataGrid ItemsSource="{Binding PortfolioStatus.CrisisWindows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="#17171A"
                                  Foreground="#EAEAEA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Start" Binding="{Binding Start}" Width="*"/>
                                <DataGridTextColumn Header="End" Binding="{Binding End}" Width="*"/>
                                <DataGridTextColumn Header="Lowest" Binding="{Binding LowestBalance}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Bottom: Audit -->
            <Border Grid.Row="1" Background="#17171A" CornerRadius="10" Padding="10" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Audit Trail"
                               Foreground="#EAEAEA"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="2,0,0,8"/>
                    <DataGrid x:Name="AuditGrid"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="#17171A"
                              Foreground="#EAEAEA"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>

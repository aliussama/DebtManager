<UserControl x:Class="DebtManager.Desktop.Controls.AttachmentsPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400"
             Background="Transparent">
    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Attachments" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Attachments.Count, StringFormat=' ({0})'}" FontSize="12"
                           Foreground="{DynamicResource App.TextMutedBrush}"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>

            <!-- Attachments List -->
            <ListBox Grid.Row="1" ItemsSource="{Binding Attachments}"
                     SelectedItem="{Binding SelectedAttachment}"
                     Background="Transparent" BorderThickness="0"
                     MaxHeight="160">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding FileName}" FontSize="12"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LinkRole, StringFormat=' [{0}]'}" FontSize="11"
                                       Foreground="{DynamicResource App.TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <TextBlock Grid.Row="1" Text="No attachments"
                       FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasNoAttachments, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Add" Command="{Binding AddAttachmentCommand}"
                        Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                <Button Content="Export" Command="{Binding ExportAttachmentCommand}"
                        Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                <Button Content="Unlink" Command="{Binding UnlinkAttachmentCommand}"
                        Padding="8,4" FontSize="11"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

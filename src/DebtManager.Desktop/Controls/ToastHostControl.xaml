<UserControl x:Class="DebtManager.Desktop.Controls.ToastHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:DebtManager.Desktop.Services"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="350"
             IsHitTestVisible="True">

    <UserControl.Resources>
        <!-- Toast Type to Color Converters -->
        <SolidColorBrush x:Key="SuccessBg" Color="#065F46"/>
        <SolidColorBrush x:Key="SuccessBorder" Color="#10B981"/>
        <SolidColorBrush x:Key="ErrorBg" Color="#7F1D1D"/>
        <SolidColorBrush x:Key="ErrorBorder" Color="#EF4444"/>
        <SolidColorBrush x:Key="InfoBg" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="InfoBorder" Color="#3B82F6"/>
        <SolidColorBrush x:Key="WarningBg" Color="#78350F"/>
        <SolidColorBrush x:Key="WarningBorder" Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF"/>

        <!-- Toast Item Template -->
        <DataTemplate x:Key="ToastTemplate" DataType="{x:Type services:ToastMessage}">
            <Border x:Name="ToastBorder"
                    Background="{StaticResource InfoBg}"
                    BorderBrush="{StaticResource InfoBorder}"
                    BorderThickness="1,1,1,1"
                    CornerRadius="10"
                    Padding="14,10"
                    Margin="0,0,0,8"
                    MinWidth="280"
                    MaxWidth="360">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <TextBlock x:Name="IconText"
                               Grid.Column="0"
                               Text="&#x2139;"
                               FontSize="16"
                               Foreground="{StaticResource TextWhite}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <!-- Message -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Message}"
                               Foreground="{StaticResource TextWhite}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>

                    <!-- Close Button -->
                    <Button Grid.Column="2"
                            Content="X"
                            Command="{Binding DataContext.DismissCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            Foreground="{StaticResource TextWhite}"
                            BorderThickness="0"
                            FontSize="12"
                            Padding="6,2"
                            Margin="8,0,0,0"
                            Cursor="Hand"
                            Opacity="0.7"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Success">
                    <Setter TargetName="ToastBorder" Property="Background" Value="{StaticResource SuccessBg}"/>
                    <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource SuccessBorder}"/>
                    <Setter TargetName="IconText" Property="Text" Value="&#x2714;"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Error">
                    <Setter TargetName="ToastBorder" Property="Background" Value="{StaticResource ErrorBg}"/>
                    <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource ErrorBorder}"/>
                    <Setter TargetName="IconText" Property="Text" Value="&#x2716;"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Warning">
                    <Setter TargetName="ToastBorder" Property="Background" Value="{StaticResource WarningBg}"/>
                    <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource WarningBorder}"/>
                    <Setter TargetName="IconText" Property="Text" Value="&#x26A0;"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Info">
                    <Setter TargetName="ToastBorder" Property="Background" Value="{StaticResource InfoBg}"/>
                    <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource InfoBorder}"/>
                    <Setter TargetName="IconText" Property="Text" Value="&#x2139;"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Toast Container - positioned at top-right -->
    <Grid IsHitTestVisible="False">
        <ItemsControl ItemsSource="{Binding Items}"
                      ItemTemplate="{StaticResource ToastTemplate}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,20,20,0"
                      IsHitTestVisible="True">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</UserControl>

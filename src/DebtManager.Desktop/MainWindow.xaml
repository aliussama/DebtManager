<Window x:Class="DebtManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DebtManager.Desktop.Views"
        Title="DebtManager - Financial Management" 
        Height="800" 
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource App.BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"
                    Command="{Binding DataContext.CreateObligationCommand, ElementName=ShellViewControl}" />
        <KeyBinding Key="P" Modifiers="Ctrl"
                    Command="{Binding DataContext.RecordPaymentCommand, ElementName=ShellViewControl}" />
        <KeyBinding Gesture="Ctrl+Shift+S"
                    Command="{Binding DataContext.SyncCommand, ElementName=ShellViewControl}" />
        <KeyBinding Key="F" Modifiers="Ctrl"
                    Command="{Binding DataContext.FocusSearchCommand, ElementName=ShellViewControl}" />
        <KeyBinding Key="Escape"
                    Command="{Binding DataContext.CloseActiveDialogCommand, ElementName=ShellViewControl}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- DataGrid theme -->
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource App.SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource App.GridRowBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource App.GridAltRowBrush}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource App.BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource App.BorderBrush}"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource App.GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.AccentSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.GridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.AccentSurfaceBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Main Shell View -->
    <views:ShellView x:Name="ShellViewControl"/>
</Window>

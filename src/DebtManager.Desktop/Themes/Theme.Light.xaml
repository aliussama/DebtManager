<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        Theme.Light.xaml - Light mode overrides.
        Professional light palette with strong readability and clean surfaces.
    -->

    <!-- Core surface colors -->
    <SolidColorBrush x:Key="App.BackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="App.SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.SurfaceAltBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="App.BorderBrush" Color="#D1D5DB"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="App.TextPrimaryBrush" Color="#111827"/>
    <SolidColorBrush x:Key="App.TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="App.TextMutedBrush" Color="#9CA3AF"/>

    <!-- Accent / brand -->
    <SolidColorBrush x:Key="App.AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="App.AccentHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="App.AccentPressedBrush" Color="#1E40AF"/>

    <!-- Semantic colors -->
    <SolidColorBrush x:Key="App.DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="App.DangerHoverBrush" Color="#B91C1C"/>
    <SolidColorBrush x:Key="App.SuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="App.SuccessHoverBrush" Color="#047857"/>
    <SolidColorBrush x:Key="App.SuccessPressedBrush" Color="#065F46"/>
    <SolidColorBrush x:Key="App.WarningBrush" Color="#D97706"/>

    <!-- Button colors -->
    <SolidColorBrush x:Key="App.ButtonBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="App.ButtonHoverBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="App.ButtonPressedBrush" Color="#C0C4CA"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="App.GridHeaderBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="App.GridRowBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.GridAltRowBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="App.GridRowHoverBrush" Color="#EEF0F4"/>

    <!-- Input controls -->
    <SolidColorBrush x:Key="App.InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="App.InputBorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="App.InputForegroundBrush" Color="#111827"/>

    <!-- Overlays -->
    <SolidColorBrush x:Key="App.OverlayBrush" Color="#40000000"/>
    <SolidColorBrush x:Key="App.HeavyOverlayBrush" Color="#80000000"/>
    <SolidColorBrush x:Key="App.OnboardingOverlayBrush" Color="#B0000000"/>

    <!-- Contextual surfaces -->
    <SolidColorBrush x:Key="App.DangerSurfaceBrush" Color="#FEF2F2"/>
    <SolidColorBrush x:Key="App.InfoSurfaceBrush" Color="#F0F4FF"/>
    <SolidColorBrush x:Key="App.SuccessSurfaceBrush" Color="#ECFDF5"/>
    <SolidColorBrush x:Key="App.AccentSurfaceBrush" Color="#EEF2FF"/>

</ResourceDictionary>

<UserControl x:Class="DebtManager.Desktop.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Accounts" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Manage your cash and bank accounts"
                           FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Filter by Tag:" FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding TagSuggestions}"
                              SelectedItem="{Binding SelectedTagFilter}"
                              Width="130" FontSize="12" Padding="6,4"
                              Background="{DynamicResource App.InputBackgroundBrush}"
                              Foreground="{DynamicResource App.InputForegroundBrush}"/>
                </StackPanel>
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New Account" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Create Account Inline Panel -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Top" Panel.ZIndex="10">
            <StackPanel>
                <TextBlock Text="Create New Account" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ACCOUNT NAME" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewAccountName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource App.InputBackgroundBrush}"
                                 Foreground="{DynamicResource App.InputForegroundBrush}"
                                 BorderBrush="{DynamicResource App.InputBorderBrush}"
                                 Padding="10,8" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TYPE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AccountTypes}" SelectedItem="{Binding NewAccountType}"
                                  Background="{DynamicResource App.InputBackgroundBrush}"
                                  Foreground="{DynamicResource App.InputForegroundBrush}"
                                  Padding="10,8" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="CURRENCY" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding NewCurrencyCode}"
                                  Background="{DynamicResource App.InputBackgroundBrush}"
                                  Foreground="{DynamicResource App.InputForegroundBrush}"
                                  Padding="10,8" FontSize="13" Width="90"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="OPENING BAL." FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewOpeningBalance, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource App.InputBackgroundBrush}"
                                 Foreground="{DynamicResource App.InputForegroundBrush}"
                                 BorderBrush="{DynamicResource App.InputBorderBrush}"
                                 Padding="10,8" FontSize="13" Width="120"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCreateCommand}" Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Create" Command="{Binding ConfirmCreateCommand}"
                            Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Accounts Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,0">
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                        <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="4"
                                                Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Archived" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,2,0,0">
                                        <Run Text="{Binding AccountType, Mode=OneWay}"/>
                                        <Run Text=" &#x00B7; "/>
                                        <Run Text="{Binding CurrencyCode, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                                           FontSize="18" FontWeight="Bold" Margin="16,0"
                                           Foreground="{DynamicResource App.TextPrimaryBrush}">
                                    <Run Text="{Binding Balance, StringFormat=N2, Mode=OneWay}"/>
                                    <Run Text=" " FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                    <Run Text="{Binding CurrencyCode, Mode=OneWay}" FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                </TextBlock>

                                <Button Grid.Column="2" VerticalAlignment="Center"
                                        Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,6" ToolTip="Archive">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="1"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Accounts Yet"
                                    Message="Create your first account to start tracking income, expenses, and transfers."
                                    IconText="&#xE825;"
                                    ActionText="Create Account"
                                    ActionCommand="{Binding ShowCreateCommand}"/>

        <!-- Loading -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

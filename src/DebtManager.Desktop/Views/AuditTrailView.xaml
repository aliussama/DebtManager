<UserControl x:Class="DebtManager.Desktop.Views.AuditTrailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             xmlns:behaviors="clr-namespace:DebtManager.Desktop.Behaviors"
             xmlns:services="clr-namespace:DebtManager.Desktop.Services"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource App.BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="24,24,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="Audit Trail" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    <TextBlock Text="View and export audit entries across your portfolio" 
                               FontSize="13" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh" 
                            Command="{Binding RefreshCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"/>
                    <Button Content="Export CSV" 
                            Command="{Binding ExportCsvCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters Bar -->
        <Border Grid.Row="1" 
                Background="{DynamicResource App.SurfaceBrush}" 
                Padding="24,16" 
                Margin="24,0,24,16"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Obligation Filter -->
                    <StackPanel Margin="0,0,16,8" MinWidth="180">
                        <TextBlock Text="Obligation" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Obligations}"
                                  SelectedItem="{Binding SelectedObligation}"
                                  DisplayMemberPath="Name"
                                  MinWidth="180"/>
                    </StackPanel>
                    
                    <!-- From Date -->
                    <StackPanel Margin="0,0,16,8" MinWidth="130">
                        <TextBlock Text="From Date" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding FromDate}" Width="130"/>
                    </StackPanel>
                    
                    <!-- To Date -->
                    <StackPanel Margin="0,0,16,8" MinWidth="130">
                        <TextBlock Text="To Date" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="130"/>
                    </StackPanel>
                    
                    <!-- Category Filter -->
                    <StackPanel Margin="0,0,16,8" MinWidth="120">
                        <TextBlock Text="Category" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Width="120"/>
                    </StackPanel>
                    
                    <!-- Severity Filter -->
                    <StackPanel Margin="0,0,16,8" MinWidth="100">
                        <TextBlock Text="Severity" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SeverityOptions}"
                                  SelectedItem="{Binding SelectedSeverity}"
                                  Width="100"/>
                    </StackPanel>
                    
                    <!-- Search -->
                    <StackPanel Margin="0,0,16,8" MinWidth="200">
                        <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200"
                                 behaviors:FocusOnRequestBehavior.FocusKey="{x:Static services:FocusTargets.AuditSearch}"
                                 behaviors:FocusOnRequestBehavior.FocusService="{DynamicResource FocusService}"/>
                    </StackPanel>
                </WrapPanel>
                
                <Button Grid.Column="1" 
                        Content="Clear Filters" 
                        Command="{Binding ClearFiltersCommand}"
                        Padding="12,6"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Audit Entries Grid -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="0">
                <Grid>
                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding ItemsView}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="{DynamicResource App.GridRowBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDateDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                            <DataGridTemplateColumn Header="Severity" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource App.WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource App.DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Severity}" 
                                                       FontSize="11" 
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Message" Binding="{Binding MessageTruncated}" Width="*"/>
                            <DataGridTextColumn Header="Obligation" Binding="{Binding ObligationDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding AtDisplay}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Empty State -->
                    <controls:EmptyStateControl 
                        Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVisibility}}"
                        IconText="&#xE81C;"
                        Title="No audit entries found"
                        Message="Adjust your filters or create some obligations with payments to see audit entries"
                        IsActionVisible="False"/>
                    
                    <!-- Loading Overlay -->
                    <Border Background="{DynamicResource App.HeavyOverlayBrush}"
                            CornerRadius="12"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                            <TextBlock Text="Loading audit trail..." 
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                       FontSize="14"
                                       Margin="0,16,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Details Panel -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="16,0,0,0"
                    Width="320"
                    Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ENTRY DETAILS" 
                                   FontSize="11" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Timestamp -->
                        <TextBlock Text="Timestamp" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.AtDisplay}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,2,0,12"/>
                        
                        <!-- Effective Date -->
                        <TextBlock Text="Effective Date" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.EffectiveDateDisplay}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,2,0,12"/>
                        
                        <!-- Category -->
                        <TextBlock Text="Category" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.Category}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,2,0,12"/>
                        
                        <!-- Severity -->
                        <TextBlock Text="Severity" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,2,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem.IsWarning}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource App.WarningBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedItem.IsError}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource App.DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedItem.Severity}" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                        
                        <!-- Message -->
                        <TextBlock Text="Message" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="8" Padding="12" Margin="0,4,0,12">
                            <TextBlock Text="{Binding SelectedItem.Message}" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                        
                        <!-- Obligation -->
                        <TextBlock Text="Obligation" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.ObligationDisplay}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,2,0,12"/>
                        
                        <!-- Obligation ID -->
                        <TextBlock Text="Obligation ID" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.ObligationId}" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   FontFamily="Consolas"
                                   Margin="0,2,0,12"/>
                        
                        <!-- Related Event ID -->
                        <TextBlock Text="Related Event ID" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.RelatedEventIdDisplay}" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   FontFamily="Consolas"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource App.SurfaceBrush}" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="12" 
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Showing " 
                               FontSize="12" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FilteredCount}" 
                               FontSize="12" 
                               Foreground="{DynamicResource App.TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" of " 
                               FontSize="12" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount}" 
                               FontSize="12" 
                               Foreground="{DynamicResource App.TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" entries" 
                               FontSize="12" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

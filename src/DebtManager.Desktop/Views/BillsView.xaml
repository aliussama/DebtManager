<UserControl x:Class="DebtManager.Desktop.Views.BillsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource App.BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Dashboard Cards -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Bills (Accounts Payable)" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
            <WrapPanel Margin="0,12,0,0">
                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,12,0" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Outstanding" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding TotalOutstanding, StringFormat=N2}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16,12" MinWidth="120">
                    <StackPanel>
                        <TextBlock Text="Overdue" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding OverdueCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource App.DangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>

        <!-- Issue Form -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Issue New Bill" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <ComboBox ItemsSource="{Binding Parties}" SelectedItem="{Binding SelectedParty}"
                              DisplayMemberPath="Name" Width="180" Margin="0,0,8,8"/>
                    <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,8" Tag="Amount"/>
                    <TextBox Text="{Binding NewCurrency, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,8,8" Tag="Currency"/>
                    <TextBox Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,8" Tag="Category"/>
                    <TextBox Text="{Binding NewReference, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,8,8" Tag="Reference"/>
                    <DatePicker SelectedDate="{Binding NewDueDate}" Width="140" Margin="0,0,8,8"/>
                    <Button Content="Issue Bill" Command="{Binding IssueBillCommand}" Style="{DynamicResource PrimaryButton}"
                            Padding="16,8" Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Payment Form -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Record Payment" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding PaymentAccount}"
                              DisplayMemberPath="Name" Width="180" Margin="0,0,8,8"/>
                    <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,8,8" Tag="Pay Amount"/>
                    <Button Content="Pay Selected Bill" Command="{Binding RecordPaymentCommand}" Style="{DynamicResource PrimaryButton}"
                            Padding="16,8" Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Bills Grid -->
        <Border Grid.Row="3" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cancel Selected" Command="{Binding CancelBillCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="Tag:" Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,6,0" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding TagSuggestions}"
                              SelectedItem="{Binding SelectedTagFilter}"
                              Width="130" FontSize="12" Padding="6,4"
                              Background="{DynamicResource App.InputBackgroundBrush}"
                              Foreground="{DynamicResource App.InputForegroundBrush}"/>
                </WrapPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Bills}" SelectedItem="{Binding SelectedBill}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource App.TextPrimaryBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource App.BorderBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="140"/>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding PartyName}" Width="150"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Outstanding" Binding="{Binding Outstanding, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Paid" Binding="{Binding TotalPaid, StringFormat=N2}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

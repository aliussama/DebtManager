<UserControl x:Class="DebtManager.Desktop.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Categories" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Organize your income and expense categories" FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New Category" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Filters + Create -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <!-- Filters -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200"
                             Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                             BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,7" FontSize="13" Margin="0,0,12,0"/>
                    <TextBlock Text="Kind:" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding KindFilterOptions}" SelectedItem="{Binding SelectedKindFilter}"
                              Width="120" Padding="8,6" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Create form -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20"
                    Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Create New Category" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NAME" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                                     BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="KIND" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding KindOptions}" SelectedItem="{Binding NewCategoryKind}" Width="120" Padding="10,8" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Cancel" Command="{Binding CancelCreateCommand}" Padding="16,8" Margin="0,0,8,0"/>
                        <Button Content="Create" Command="{Binding ConfirmCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Items -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ItemsView}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                        <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Archived" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Kind}" FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3" Margin="8,0" VerticalAlignment="Center"
                                        Background="{DynamicResource App.SurfaceAltBrush}">
                                    <TextBlock Text="{Binding Kind}" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="2" VerticalAlignment="Center"
                                        Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" Padding="8,6" ToolTip="Archive">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="2"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Categories Yet"
                                    Message="Create categories to organize your income and expenses."
                                    IconText="&#xE8FD;"
                                    ActionText="Create Category"
                                    ActionCommand="{Binding ShowCreateCommand}"/>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

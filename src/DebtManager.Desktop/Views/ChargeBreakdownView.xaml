<UserControl x:Class="DebtManager.Desktop.Views.ChargeBreakdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Charge Breakdown" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Export CSV" 
                        Command="{Binding ExportCsvCommand}"
                        Padding="12,8"
                        Margin="0,0,8,0"/>
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Padding="12,8"/>
            </StackPanel>
        </Grid>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Obligation Dropdown -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Obligation:" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Obligations}"
                              SelectedItem="{Binding SelectedObligation}"
                              DisplayMemberPath="Name"
                              Width="220"
                              FontSize="13"
                              Padding="8,6"/>
                </StackPanel>

                <!-- As-Of Date -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBlock Text="As Of:" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding AsOfDate}"
                                Width="130"
                                FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- No Obligations Empty State -->
        <Border Grid.Row="2" Grid.RowSpan="2"
                Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20"
                Visibility="{Binding HasNoObligations, Converter={StaticResource BoolToVis}}">
            <controls:EmptyStateControl 
                IconText="&#xE825;"
                Title="No obligations found"
                Message="Create an obligation first to view charge breakdowns."
                ActionText="Create Obligation"
                ActionCommand="{Binding CreateObligationCommand}"
                IsActionVisible="True"/>
        </Border>

        <!-- Summary Section -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                Visibility="{Binding HasSelectedObligation, Converter={StaticResource BoolToVis}}">
            <Grid>
                <!-- No Charges Empty State -->
                    <controls:EmptyStateControl 
                    IconText="&#x2714;"
                    Title="No charges as of date"
                    Message="No interest, penalties, or fees have been assessed as of the selected date."
                    IsActionVisible="False"
                    Visibility="{Binding HasNoCharges, Converter={StaticResource BoolToVis}}"/>

                <!-- Summary Grid -->
                <StackPanel Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="SUMMARY BY CHARGE TYPE" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding SummaryRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="{DynamicResource App.GridRowBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding ChargeType}" Width="120"/>
                            <DataGridTextColumn Header="Total Assessed" Binding="{Binding TotalAssessed, StringFormat=N2}" Width="130"/>
                            <DataGridTextColumn Header="Total Paid" Binding="{Binding TotalPaid, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Outstanding" Binding="{Binding Outstanding, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="70"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Detail Section -->
        <Grid Grid.Row="3" Visibility="{Binding HasSelectedObligation, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Charges Detail Grid -->
            <Border Grid.Column="0" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20"
                    Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="CHARGE DETAILS" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="{DynamicResource App.GridRowBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDateDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding ChargeType}" Width="90"/>
                            <DataGridTextColumn Header="Assessed" Binding="{Binding AssessedAmount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingAmount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="16,0,0,0"
                    Width="280"
                    Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Charge Details" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="CHARGE ID" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBox Text="{Binding SelectedItem.ChargeId, Mode=OneWay}" 
                                 FontSize="12" 
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource App.TextPrimaryBrush}"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="TYPE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.ChargeType}" 
                                   FontSize="14" 
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="DATE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.EffectiveDateDisplay}" 
                                   FontSize="14" 
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="ASSESSED" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock FontSize="20" FontWeight="Bold" Margin="0,4,0,12">
                            <Run Text="{Binding SelectedItem.AssessedAmount, StringFormat=N2}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SelectedItem.CurrencyCode}" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        </TextBlock>

                        <TextBlock Text="PAID" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.PaidAmount, StringFormat=N2}" 
                                   FontSize="14"
                                   Foreground="{DynamicResource App.SuccessBrush}"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="OUTSTANDING" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.OutstandingAmount, StringFormat=N2}" 
                                   FontSize="14"
                                   Foreground="{DynamicResource App.DangerBrush}"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="RELATED EVENT" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBox Text="{Binding SelectedItem.RelatedEventId, Mode=OneWay}" 
                                 FontSize="12" 
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource App.TextPrimaryBrush}"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="NOTES" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.Notes, TargetNullValue='-'}" 
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4" 
                Background="{DynamicResource App.OverlayBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Loading..." 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

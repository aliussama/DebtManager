<UserControl x:Class="DebtManager.Desktop.Views.CreateObligationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="450"
             Background="{DynamicResource App.SurfaceBrush}">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border CornerRadius="16" Padding="32">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Create New Obligation" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                       Margin="0,0,0,24"/>

            <!-- Name Field -->
            <TextBlock Text="NAME" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource FormInput}"/>
            <TextBlock Text="{Binding NameError}" 
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding NameError, Converter={StaticResource NullToCollapsed}}"/>

            <!-- Type Field -->
            <TextBlock Text="TYPE" Style="{StaticResource FormLabel}"/>
            <ComboBox ItemsSource="{Binding ObligationTypes}" 
                      SelectedItem="{Binding ObligationType}"
                      Style="{StaticResource FormComboBox}"/>
            <TextBlock Text="" Style="{StaticResource ErrorText}"/>

            <!-- Principal Field -->
            <TextBlock Text="PRINCIPAL AMOUNT" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Principal, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource FormInput}"/>
            <TextBlock Text="{Binding PrincipalError}" 
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding PrincipalError, Converter={StaticResource NullToCollapsed}}"/>

            <!-- Currency Field -->
            <TextBlock Text="CURRENCY" Style="{StaticResource FormLabel}"/>
            <ComboBox ItemsSource="{Binding Currencies}" 
                      SelectedItem="{Binding CurrencyCode}"
                      Style="{StaticResource FormComboBox}"/>
            <TextBlock Text="" Style="{StaticResource ErrorText}"/>

            <!-- Start Date Field -->
            <TextBlock Text="START DATE" Style="{StaticResource FormLabel}"/>
            <DatePicker SelectedDate="{Binding StartDate, Converter={StaticResource DateOnlyConverter}}"
                        Background="{DynamicResource App.InputBackgroundBrush}"
                        Foreground="{DynamicResource App.InputForegroundBrush}"
                        BorderBrush="{DynamicResource App.InputBorderBrush}"
                        Padding="12,10"
                        Margin="0,0,0,16"/>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" 
                       Style="{StaticResource ErrorText}"
                       FontWeight="SemiBold"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"/>
                <Button Content="Create Obligation" 
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>

            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="True" 
                         Height="3" 
                         Margin="0,16,0,0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="DebtManager.Desktop.Views.DataQualityView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d"
d:DesignHeight="600" d:DesignWidth="1000"
Background="{DynamicResource App.BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Data Health" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="{Binding LastScanDisplay}" FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="Run Scan" Command="{Binding RunScanCommand}"
                        Padding="14,8" Margin="0,0,8,0"
                        Background="{DynamicResource App.AccentBrush}" Foreground="White" FontWeight="SemiBold"/>
                <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"
                        Padding="14,8"/>
            </StackPanel>
        </DockPanel>

        <!-- Summary Cards -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,12,0" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="TOTAL" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalIssues}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,12,0" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="CRITICAL" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding CriticalCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.DangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,12,0" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="ERRORS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding ErrorCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.DangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,12,0" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="WARNINGS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding WarningCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.WarningBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20,16" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="INFO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding InfoCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource App.AccentBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16,10" Margin="0,0,0,16">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="Severity:" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SelectedSeverity}"
                              MinWidth="100"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="Area:" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AreaOptions}" SelectedItem="{Binding SelectedArea}"
                              MinWidth="120"/>
                </StackPanel>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="180" Margin="0,0,16,4" Padding="6,5"
                         Tag="Search issues..."/>
                <CheckBox Content="Unresolved only" IsChecked="{Binding OnlyUnresolved}"
                          VerticalAlignment="Center" Margin="0,0,0,4"
                          Foreground="{DynamicResource App.TextSecondaryBrush}"/>
            </WrapPanel>
        </Border>

        <!-- Issues Grid + Detail Panel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="16">
                <DataGrid ItemsSource="{Binding Issues}"
                          SelectedItem="{Binding SelectedIssue}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="{DynamicResource App.GridRowBrush}"
                          AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                          Foreground="{DynamicResource App.TextPrimaryBrush}"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="70"/>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="85"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                        <DataGridTemplateColumn Header="Actions" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Fix"
                                                Command="{Binding DataContext.PreviewFixCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3" Margin="0,0,4,0" FontSize="11"
                                                Background="{DynamicResource App.AccentBrush}" Foreground="White"/>
                                        <Button Content="Ack"
                                                Command="{Binding DataContext.AcknowledgeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3" Margin="0,0,4,0" FontSize="11"/>
                                        <Button Content="Resolve"
                                                Command="{Binding DataContext.ResolveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,3" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12"
                    Padding="16" Margin="12,0,0,0" Width="300"
                    Visibility="{Binding HasSelectedIssue, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Issue Details" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="CODE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedIssue.Code}" FontSize="13"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <TextBlock Text="SEVERITY" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedIssue.Severity}" FontSize="13"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <TextBlock Text="AREA" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedIssue.Area}" FontSize="13"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedIssue.Description}" FontSize="12"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,10"/>

                        <TextBlock Text="EVIDENCE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding SelectedIssue.EvidenceJson}" FontSize="11"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,10"
                                   FontFamily="Consolas"/>

                        <!-- Preview -->
                        <TextBlock Text="FIX PREVIEW" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   Visibility="{Binding PreviewText, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="{Binding PreviewText}" FontSize="11"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,10"
                                   Visibility="{Binding PreviewText, Converter={StaticResource NullToCollapsed}}"/>

                        <!-- Apply Fix Button -->
                        <Button Content="Apply Fix" 
                                Command="{Binding ApplyFixCommand}"
                                CommandParameter="{Binding SelectedIssue}"
                                Padding="14,8" Margin="0,8,0,0"
                                Background="{DynamicResource App.AccentBrush}" Foreground="White" FontWeight="SemiBold"
                                Visibility="{Binding ShowConfirmDialog, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4"
                Background="{DynamicResource App.OverlayBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Scanning..." Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

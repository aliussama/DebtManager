<UserControl x:Class="DebtManager.Desktop.Views.ForecastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource App.BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Forecast" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Deterministic cashflow, budget, and goal projections"
                       FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,20"/>

            <!-- Dashboard cards -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding Dashboard, Converter={StaticResource NullToCollapsed}}">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="CASH RUNWAY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Dashboard.CashRunwayDays, StringFormat='{}{0:N0} days'}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="NEXT MONTH NET" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Dashboard.NextMonthNetCashflow, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="UPCOMING DUE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Dashboard.UpcomingRecurringCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Controls -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="START" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Width="140"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="END" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Width="140"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="GRANULARITY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding GranularityOptions}" SelectedItem="{Binding SelectedGranularity}" Width="120"/>
                        </StackPanel>
                        <Button Command="{Binding RefreshBaselineCommand}" Content="Run Forecast"
                                Background="{DynamicResource App.AccentBrush}" Foreground="White"
                                BorderThickness="0" Padding="20,8" FontWeight="SemiBold" Cursor="Hand"
                                VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                        <Button Command="{Binding ExportBaselineCsvCommand}" Content="Export CSV"
                                Padding="20,8" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Cashflow Breakdown -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding Report, Converter={StaticResource NullToCollapsed}}">
                <StackPanel>
                    <TextBlock Text="Cashflow Breakdown" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding CashflowRows}" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource App.BackgroundBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="Reporting Amount" Binding="{Binding ReportingAmount, StringFormat=N2}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Budget Forecast -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding Report, Converter={StaticResource NullToCollapsed}}">
                <StackPanel>
                    <TextBlock Text="Budget Forecast" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding BudgetRows}" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource App.BackgroundBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="60"/>
                            <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="60"/>
                            <DataGridTextColumn Header="Scope" Binding="{Binding ScopeLabel}" Width="*"/>
                            <DataGridTextColumn Header="Limit" Binding="{Binding Limit, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Forecast" Binding="{Binding ForecastActual, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="%" Binding="{Binding Percent, StringFormat=N1}" Width="60"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Goal Forecast -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding Report, Converter={StaticResource NullToCollapsed}}">
                <StackPanel>
                    <TextBlock Text="Goal Forecast" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding GoalRows}" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource App.BackgroundBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Goal" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetAmount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Contributed" Binding="{Binding ForecastContributed, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Remaining" Binding="{Binding Remaining, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="%" Binding="{Binding ProgressPercent, StringFormat=N1}" Width="60"/>
                            <DataGridTextColumn Header="Est. Completion" Binding="{Binding EstimatedCompletionDate}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding Report, Converter={StaticResource NullToCollapsed}}">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="NET CASHFLOW" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Report.Summary.KnownNetCashflow, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="END BALANCE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Report.Summary.KnownEndBalance, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="UNKNOWN" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                        <TextBlock Text="{Binding Report.Summary.UnknownCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

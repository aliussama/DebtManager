<UserControl x:Class="DebtManager.Desktop.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource App.BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Help &amp; Troubleshooting" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
            <TextBlock Text="Offline reference - no internet required" FontSize="13"
                       Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8"
                Padding="12" Margin="0,0,0,16">
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Background="{DynamicResource App.InputBackgroundBrush}"
                     Foreground="{DynamicResource App.InputForegroundBrush}"
                     BorderBrush="{DynamicResource App.InputBorderBrush}"
                     Padding="12,8" FontSize="14"
                     AutomationProperties.Name="Search help articles"/>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Article List -->
            <Border Grid.Column="0" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8">
                <ListBox ItemsSource="{Binding Articles}"
                         SelectedItem="{Binding SelectedArticle}"
                         Background="Transparent" BorderThickness="0"
                         Padding="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Category}" FontSize="11"
                                           Foreground="{DynamicResource App.TextMutedBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Article Body -->
            <Border Grid.Column="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedArticle.Title}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedArticle.Category}" FontSize="12"
                                   Foreground="{DynamicResource App.AccentBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding SelectedArticle.Body}" FontSize="13"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Diagnostics Footer -->
        <Border Grid.Row="3" Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding DiagnosticsText}" FontSize="11"
                           Foreground="{DynamicResource App.TextMutedBrush}"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Copy Diagnostics" Command="{Binding CopyDiagnosticsCommand}"
                        Padding="12,6" FontSize="12" Margin="8,0"
                        AutomationProperties.Name="Copy diagnostics to clipboard"
                        ToolTip="Copy app version, OS, and correlation ID to clipboard"/>
                <Button Grid.Column="2" Content="Open Logs" Command="{Binding OpenLogsFolderCommand}"
                        Padding="12,6" FontSize="12"
                        AutomationProperties.Name="Open logs folder"
                        ToolTip="Open the logs folder in file explorer"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

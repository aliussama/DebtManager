<UserControl x:Class="DebtManager.Desktop.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Bank Import" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Import CSV transactions and reconcile with your ledger" FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="4" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SwitchToImportCommand}" Padding="16,8" Margin="0,0,4,0">
                    <TextBlock Text="Import &amp; Reconcile" FontSize="13"/>
                </Button>
                <Button Command="{Binding SwitchToProfilesCommand}" Padding="16,8">
                    <TextBlock Text="Profiles" FontSize="13"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <Grid Grid.Row="2">
            <!-- Import & Reconcile Tab -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="Import">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <!-- Step 1: Select Account + Profile + File -->
                    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Step 1: Select Account, Profile, and CSV File" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ACCOUNT" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                                              DisplayMemberPath="Name" Padding="10,8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="IMPORT PROFILE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                              DisplayMemberPath="Name" Padding="10,8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                    <Button Command="{Binding PickCsvFileCommand}" Padding="16,9">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Pick CSV" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding CsvFilePath}" FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Command="{Binding PreviewImportCommand}" Padding="16,8" Margin="0,0,8,0">
                                    <TextBlock Text="Preview" FontSize="12"/>
                                </Button>
                                <Button Command="{Binding RunImportCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"
                                        Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Run Import" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Duplicate batch warning -->
                    <Border Background="#FFF3CD" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                            Visibility="{Binding PreviewIsDuplicateBatch, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="? This file has already been imported for this account/profile. Re-import is blocked."
                                   FontSize="13" Foreground="#856404"/>
                    </Border>

                    <!-- Preview summary -->
                    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12"
                            Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,16,0">
                                <Run Text="Total rows: "/><Run Text="{Binding PreviewTotalRows, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,16,0">
                                <Run Text="Duplicates skipped: "/><Run Text="{Binding PreviewDuplicateRows, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}">
                                <Run Text="New rows: "/><Run Text="{Binding PreviewRows.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Preview rows DataGrid -->
                    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="4" Margin="0,0,0,12"
                            Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}" MaxHeight="300">
                        <DataGrid ItemsSource="{Binding PreviewRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource App.BorderBrush}" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding TxnDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="80"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Counterparty" Binding="{Binding Counterparty}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Import completed / Reconciliation -->
                    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12"
                            Visibility="{Binding ImportCompleted, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Reconciliation" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.TextPrimaryBrush}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                    <Button Command="{Binding BulkApplyCommand}" Padding="12,7" Margin="0,0,8,0"
                                            Background="{DynamicResource App.AccentBrush}" Foreground="White">
                                        <TextBlock Text="Bulk Apply Unmatched" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding UndoBatchCommand}" Padding="12,7" Margin="0,0,8,0">
                                        <TextBlock Text="Undo Batch" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding LoadReconciliationCommand}" Padding="12,7" Margin="0,0,8,0">
                                        <TextBlock Text="Refresh" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding ExportReconciliationCommand}" Padding="12,7">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Export" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>

                            <DataGrid ItemsSource="{Binding ReconciliationRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                                      Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource App.BorderBrush}" FontSize="12" MaxHeight="400">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding TxnDate, StringFormat=yyyy-MM-dd}" Width="90"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="90"/>
                                    <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="60"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTextColumn Header="Match" Binding="{Binding MatchType}" Width="70"/>
                                    <DataGridTextColumn Header="Conf" Binding="{Binding Confidence, StringFormat=P0}" Width="60"/>
                                    <DataGridTemplateColumn Header="Actions" Width="420">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Income" Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                            Command="{Binding DataContext.ApplyAsIncomeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Expense" Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                            Command="{Binding DataContext.ApplyAsExpenseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Match" Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                            Command="{Binding DataContext.MatchCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Ignore" Padding="6,3" FontSize="11" Margin="0,0,8,0"
                                                            Command="{Binding DataContext.IgnoreCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Split" Padding="6,3" FontSize="11" Margin="0,0,8,0" ToolTip="Split before apply"
                                                            Background="{DynamicResource App.AccentBrush}" Foreground="White"
                                                            Command="{Binding DataContext.StartSplitForSelectedRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Undo" Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                            Command="{Binding DataContext.UndoDecisionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="?Income" Padding="6,3" FontSize="10" Margin="0,0,2,0" ToolTip="Correct to Income"
                                                            Command="{Binding DataContext.CorrectToIncomeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="?Expense" Padding="6,3" FontSize="10" Margin="0,0,2,0" ToolTip="Correct to Expense"
                                                            Command="{Binding DataContext.CorrectToExpenseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="?Ignore" Padding="6,3" FontSize="10" ToolTip="Correct to Ignore"
                                                            Command="{Binding DataContext.CorrectToIgnoreCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Split-before-apply editor -->
                            <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="10" Padding="16" Margin="0,12,0,0"
                                    Visibility="{Binding IsImportSplitMode, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8">
                                        <Run Text="Split Import Row: "/><Run Text="{Binding SplitTargetRow.Description, Mode=OneWay}" FontWeight="Normal"/>
                                        <Run Text=" - "/><Run Text="{Binding SplitTargetRow.Amount, Mode=OneWay, StringFormat=N2}" FontWeight="SemiBold"/>
                                        <Run Text=" "/><Run Text="{Binding SplitTargetRow.CurrencyCode, Mode=OneWay}"/>
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding ImportSplitLines}" Margin="0,0,0,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <ComboBox ItemsSource="{Binding DataContext.ImportSplitCategories, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEditable="True" Width="160" Padding="8,6" FontSize="12" Margin="0,0,8,0"/>
                                                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="100" Padding="8,6" FontSize="12" Margin="0,0,8,0"
                                                             Background="{DynamicResource App.InputBackgroundBrush}"
                                                             Foreground="{DynamicResource App.InputForegroundBrush}"
                                                             BorderBrush="{DynamicResource App.InputBorderBrush}"/>
                                                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="160" Padding="8,6" FontSize="12" Margin="0,0,8,0"
                                                             Background="{DynamicResource App.InputBackgroundBrush}"
                                                             Foreground="{DynamicResource App.InputForegroundBrush}"
                                                             BorderBrush="{DynamicResource App.InputBorderBrush}"/>
                                                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Padding="6,4"
                                                            Command="{Binding DataContext.RemoveImportSplitLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" ToolTip="Remove line"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Content="+ Add Line" Command="{Binding AddImportSplitLineCommand}" Padding="10,5" FontSize="11" Margin="0,0,16,0"/>
                                        <TextBlock FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}">
                                            <Run Text="Split total: "/><Run Text="{Binding ImportSplitTotal, Mode=OneWay, StringFormat=N2}" FontWeight="SemiBold"
                                                                             Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                            <Run Text=" / "/><Run Text="{Binding SplitTargetRow.Amount, Mode=OneWay, StringFormat=N2}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ImportSplitError}" FontSize="12" Foreground="{DynamicResource App.DangerBrush}" Margin="0,0,0,4"
                                               Visibility="{Binding ImportSplitError, Converter={StaticResource NullToCollapsed}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Apply Split" Command="{Binding ApplySplitCommand}" Padding="14,8"
                                                Background="{DynamicResource App.AccentBrush}" Foreground="White" FontSize="12" Margin="0,0,8,0"/>
                                        <Button Content="Cancel" Command="{Binding CancelSplitForSelectedRowCommand}" Padding="14,8" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Profiles Tab -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="Profiles">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <!-- Create profile button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button Command="{Binding ShowCreateProfileCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="New Profile" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Create form -->
                    <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12"
                            Visibility="{Binding IsCreateProfileVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Create Import Profile" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="NAME" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                                     BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="13" Margin="0,0,0,12"/>
                            <TextBlock Text="MAPPING JSON" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewProfileMappingJson, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                                     BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="12"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="250"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Cancel" Command="{Binding CancelCreateProfileCommand}" Padding="16,8" Margin="0,0,8,0"/>
                                <Button Content="Create" Command="{Binding ConfirmCreateProfileCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Profile list -->
                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                                <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                        Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Archived" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ProfileId}" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Center"
                                                Command="{Binding DataContext.ArchiveProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Padding="8,6" ToolTip="Archive">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <controls:EmptyStateControl
                        Visibility="{Binding IsProfilesEmpty, Converter={StaticResource BoolToVis}}"
                        Title="No Import Profiles"
                        Message="Create an import profile to define how your bank's CSV format should be parsed."
                        IconText="&#xE8E5;"
                        ActionText="Create Profile"
                        ActionCommand="{Binding ShowCreateProfileCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

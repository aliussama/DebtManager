<UserControl x:Class="DebtManager.Desktop.Views.IncomeSourcesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Income Sources" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Define and manage your income sources for tracking and reporting" FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportCsvCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Export" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New Source" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Summary Cards -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="CLASSIFIED (12m)" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalClassified, StringFormat=N2}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.SuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="UNCLASSIFIED (12m)" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalUnclassified, StringFormat=N2}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.WarningBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Create form -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12"
                Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Create New Income Source" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NAME" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                                 BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TYPE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SourceTypeOptions}" SelectedItem="{Binding NewSourceType}" Width="140" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="CURRENCY" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewCurrency, UpdateSourceTrigger=PropertyChanged}" Width="80"
                                 Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                                 BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                        <CheckBox Content="Recurring" IsChecked="{Binding NewIsRecurring}" FontSize="13" Padding="4,0"/>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="NOTES (optional)" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource App.InputBackgroundBrush}" Foreground="{DynamicResource App.InputForegroundBrush}"
                             BorderBrush="{DynamicResource App.InputBorderBrush}" Padding="10,8" FontSize="13" MaxLength="500"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCreateCommand}" Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Create" Command="{Binding CreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Sources List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                        <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Archived" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,2,0,0">
                                        <Run Text="{Binding SourceType, Mode=OneWay}"/>
                                        <Run Text=" &#x00B7; "/>
                                        <Run Text="{Binding CurrencyCode, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="4" Padding="8,3" Margin="8,0" VerticalAlignment="Center"
                                        Background="{DynamicResource App.SurfaceAltBrush}">
                                    <TextBlock Text="{Binding TotalReceived, StringFormat=N2}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource App.SuccessBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding LastReceivedDate, StringFormat=yyyy-MM-dd}" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}" VerticalAlignment="Center" Margin="8,0"/>
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2" Margin="4,0" VerticalAlignment="Center"
                                        Background="{DynamicResource App.SurfaceAltBrush}"
                                        Visibility="{Binding IsRecurring, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Recurring" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="4" VerticalAlignment="Center"
                                        Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" Padding="8,6" ToolTip="Archive">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="3"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Income Sources Yet"
                                    Message="Define income sources to track and report your income by source."
                                    IconText="&#xE946;"
                                    ActionText="Create Source"
                                    ActionCommand="{Binding ShowCreateCommand}"/>

        <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

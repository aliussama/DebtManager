<UserControl x:Class="DebtManager.Desktop.Views.InvestmentAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Investment Accounts" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Manage your brokerage and investment accounts"
                           FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Tag:" FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding TagSuggestions}"
                              SelectedItem="{Binding SelectedTagFilter}"
                              Width="130" FontSize="12" Padding="6,4"
                              Background="{DynamicResource App.InputBackgroundBrush}"
                              Foreground="{DynamicResource App.InputForegroundBrush}"/>
                </StackPanel>
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowCreateCommand}" Style="{StaticResource PrimaryButton}" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New Account" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Create Form -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="NEW INVESTMENT ACCOUNT" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Account Name" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewAccountName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0">
                        <TextBlock Text="Currency" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding NewCurrencyCode}" Padding="8,6" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                        <TextBlock Text="Broker Name" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewBrokerName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="12"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Command="{Binding ConfirmCreateCommand}" Style="{StaticResource PrimaryButton}" Content="Create" Padding="16,6" Margin="0,0,8,0"/>
                    <Button Command="{Binding CancelCreateCommand}" Content="Cancel" Padding="16,6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Accounts Grid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Accounts}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True"
                  Background="{DynamicResource App.SurfaceBrush}"
                  Foreground="{DynamicResource App.TextPrimaryBrush}"
                  BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource App.BorderBrush}"
                  RowBackground="{DynamicResource App.SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource App.BackgroundBrush}"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="80"/>
                <DataGridTextColumn Header="Broker" Binding="{Binding BrokerName}" Width="150"/>
                <DataGridTextColumn Header="Mode" Binding="{Binding CostBasisMode}" Width="100"/>
                <DataGridTextColumn Header="Cash Balance" Binding="{Binding CashBalance, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Archived" Binding="{Binding IsArchived}" Width="80"/>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Archive" FontSize="11" Padding="6,2"
                                    Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="2"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Investment Accounts"
                                    Message="Create an investment account to start tracking your portfolio."
                                    IconText="&#xE825;"/>

        <!-- Loading -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

<UserControl x:Class="DebtManager.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="400"
             Background="{DynamicResource App.BackgroundBrush}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
        <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="32">
            <StackPanel>
                <!-- Logo -->
                <Border Background="{DynamicResource App.AccentBrush}" CornerRadius="10"
                        Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="DebtManager" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Sign in to your vault" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,24"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,12" FontSize="13"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,0,0,12" FontSize="13"/>

                <!-- Remember Me -->
                <CheckBox Content="Remember me" IsChecked="{Binding RememberMe}"
                          Margin="0,0,0,16" FontSize="12"
                          Foreground="{DynamicResource App.TextSecondaryBrush}"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}" FontSize="11" Foreground="Red"
                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                <!-- Login Button -->
                <Button Content="Sign In" Command="{Binding LoginCommand}"
                        Background="{DynamicResource App.AccentBrush}"
                        Foreground="White" Padding="12,10"
                        HorizontalAlignment="Stretch" FontSize="14"
                        Cursor="Hand" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

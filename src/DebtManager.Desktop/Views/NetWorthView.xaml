<UserControl x:Class="DebtManager.Desktop.Views.NetWorthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             xmlns:converters="clr-namespace:DebtManager.Desktop.Converters"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Net Worth" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Your complete financial picture - assets, cash, and liabilities"
                           FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="AS OF" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,2"/>
                    <DatePicker SelectedDate="{Binding AsOfDate}" FontSize="12" Width="140"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="CURRENCY" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding SelectedCurrency}"
                              Background="{DynamicResource App.InputBackgroundBrush}"
                              Foreground="{DynamicResource App.InputForegroundBrush}"
                              Padding="8,6" FontSize="12" Width="80"/>
                </StackPanel>
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportCommand}" Padding="12,8" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Export" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="NET WORTH" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding KnownNetWorth, StringFormat=N2}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource App.AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="TOTAL ASSETS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalAssets, StringFormat=N2}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="CASH" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalCash, StringFormat=N2}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="INVESTMENTS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalInvestmentAssets, StringFormat=N2}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="LIABILITIES" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.TextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalLiabilities, StringFormat=N2}" FontSize="18" FontWeight="SemiBold"
                               Foreground="IndianRed" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Unknown values warning -->
        <Border Grid.Row="2" Background="#2EFFBB33" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                Visibility="{Binding UnknownValueCount, Converter={StaticResource BoolToVis}}">
            <TextBlock FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}">
                <Run Text="?"/>
                <Run Text="{Binding UnknownValueCount, Mode=OneWay}"/>
                <Run Text=" item(s) could not be valued due to missing prices or FX rates. They are excluded from totals."/>
            </TextBlock>
        </Border>

        <!-- View Mode Toggle -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Left">
            <Button Content="Breakdown" Padding="12,6" Margin="0,0,4,0"
                    Command="{Binding ToggleBalanceSheetCommand}"
                    Background="{DynamicResource App.SurfaceBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    AutomationProperties.Name="Switch to Breakdown View">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Opacity" Value="0.6"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBalanceSheetMode}" Value="False">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Balance Sheet" Padding="12,6"
                    Command="{Binding ToggleBalanceSheetCommand}"
                    Background="{DynamicResource App.SurfaceBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    AutomationProperties.Name="Switch to Balance Sheet View">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Opacity" Value="0.6"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBalanceSheetMode}" Value="True">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Breakdown Grid (existing) -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True"
                  Background="{DynamicResource App.SurfaceBrush}"
                  Foreground="{DynamicResource App.TextPrimaryBrush}"
                  BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource App.BorderBrush}"
                  RowBackground="{DynamicResource App.SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource App.BackgroundBrush}"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  AutomationProperties.Name="Net Worth Breakdown">
            <DataGrid.Visibility>
                <Binding Path="IsBalanceSheetMode" Converter="{StaticResource InverseBoolToVis}" ConverterParameter="Inverse"/>
            </DataGrid.Visibility>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Type" Binding="{Binding SubCategory}" Width="120"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Native Ccy" Binding="{Binding NativeCurrencyCode}" Width="80"/>
                <DataGridTextColumn Header="Native Amount" Binding="{Binding NativeAmount, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Report Ccy" Binding="{Binding ReportingCurrencyCode}" Width="80"/>
                <DataGridTextColumn Header="Report Amount" Binding="{Binding ReportingAmount, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Note" Binding="{Binding ValuationNote}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- B6 Balance Sheet View -->
        <Grid Grid.Row="3" AutomationProperties.Name="Balance Sheet">
            <Grid.Visibility>
                <Binding Path="IsBalanceSheetMode" Converter="{StaticResource BoolToVis}"/>
            </Grid.Visibility>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Assets Column -->
            <Border Grid.Column="0" Background="{DynamicResource App.SurfaceBrush}"
                    BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ASSETS" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource App.SuccessBrush}" Margin="0,0,0,12"/>

                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource App.BackgroundBrush}"
                            CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="TOTAL ASSETS" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding BalanceSheetTotalAssets, StringFormat=N2}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource App.SuccessBrush}" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding BalanceSheetAssets}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                       Margin="0,8,0,4"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,2">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="12"
                                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding AmountDisplay}" FontSize="12"
                                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                                       HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Liabilities Column -->
            <Border Grid.Column="2" Background="{DynamicResource App.SurfaceBrush}"
                    BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LIABILITIES" FontSize="16" FontWeight="Bold"
                               Foreground="IndianRed" Margin="0,0,0,12"/>

                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource App.BackgroundBrush}"
                            CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="TOTAL LIABILITIES" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding BalanceSheetTotalLiabilities, StringFormat=N2}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="IndianRed" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding BalanceSheetLiabilities}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                       Margin="0,8,0,4"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,2">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="12"
                                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding AmountDisplay}" FontSize="12"
                                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                                       HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Equity Line (Balance Sheet Mode Only) -->
        <Border Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,16"
                Background="{DynamicResource App.AccentBrush}" CornerRadius="8" Padding="20,14"
                Visibility="{Binding IsBalanceSheetMode, Converter={StaticResource BoolToVis}}"
                AutomationProperties.Name="Equity">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="EQUITY (Assets - Liabilities)" FontSize="14" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding BalanceSheetEquity, StringFormat=N2}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Balance Sheet Unknown Warning -->
        <Border Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,70"
                Background="#2EFFBB33" CornerRadius="6" Padding="10"
                Visibility="{Binding BalanceSheetUnknownCount, Converter={StaticResource BoolToVis}}"
                AutomationProperties.Name="Unknown Values Warning">
            <TextBlock FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}">
                <Run Text="?"/>
                <Run Text="{Binding BalanceSheetUnknownCount, Mode=OneWay}"/>
                <Run Text=" item(s) excluded from balance sheet due to missing values."/>
            </TextBlock>
        </Border>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="3"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Data"
                                    Message="Add accounts, assets, and obligations to see your net worth."
                                    IconText="&#xE9F9;"/>

        <!-- Loading -->
        <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

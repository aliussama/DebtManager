<UserControl x:Class="DebtManager.Desktop.Views.ObligationDetailView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
mc:Ignorable="d"
d:DesignHeight="800" d:DesignWidth="1200"
Background="{DynamicResource App.BackgroundBrush}">

<UserControl.Resources>
    <Style x:Key="StatLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource App.TextMutedBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="StatValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource App.ButtonBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Background" Value="{DynamicResource App.DangerBrush}"/>
    </Style>

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
</UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Command="{Binding BackCommand}"
                    Background="Transparent"
                    Padding="8,6"
                    Margin="0,0,12,0"
                    ToolTip="Back to Dashboard">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                               Margin="0,0,6,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                    <TextBlock Text="Back" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Name}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ActionButton}"/>
                <Button Content="+ Record Payment" 
                        Command="{Binding RecordPaymentCommand}"
                        Style="{StaticResource PrimaryActionButton}"/>
                <Button Content="+ Define Schedule" 
                        Command="{Binding DefineScheduleCommand}"
                        Style="{StaticResource ActionButton}"/>
                <Button Content="X Close Obligation" 
                        Command="{Binding CloseObligationCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Summary Cards -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="PRINCIPAL" Style="{StaticResource StatLabel}"/>
                    <TextBlock Style="{StaticResource StatValue}">
                        <Run Text="{Binding Principal, StringFormat=N0}"/>
                        <Run Text=" " FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <Run Text="{Binding CurrencyCode}" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="TOTAL PAID" Style="{StaticResource StatLabel}"/>
                    <TextBlock Style="{StaticResource StatValue}" Foreground="{DynamicResource App.SuccessBrush}">
                        <Run Text="{Binding TotalPaid, StringFormat=N0}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="OUTSTANDING" Style="{StaticResource StatLabel}"/>
                    <TextBlock Style="{StaticResource StatValue}">
                        <Run Text="{Binding Outstanding, StringFormat=N0}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="INSTALLMENTS" Style="{StaticResource StatLabel}"/>
                    <TextBlock Style="{StaticResource StatValue}">
                        <Run Text="{Binding PaidInstallments}"/>
                        <Run Text="/" FontSize="14"/>
                        <Run Text="{Binding TotalInstallments}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="OVERDUE" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding OverdueInstallments}" 
                               Style="{StaticResource StatValue}" 
                               Foreground="{DynamicResource App.DangerBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="5">
                    <TextBlock Text="HEALTH" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding HealthStatus}" 
                               Style="{StaticResource StatValue}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding ErrorMessage}" 
                   Foreground="{DynamicResource App.DangerBrush}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

        <!-- Tabs: Installments, Payments & Audit -->
        <TabControl Grid.Row="3" 
                    Background="Transparent" 
                    BorderThickness="0"
                    Foreground="{DynamicResource App.TextPrimaryBrush}">
            
            <!-- Installments Tab -->
            <TabItem Header="Installments" Foreground="{DynamicResource App.TextPrimaryBrush}">
                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="0,12,12,12" Padding="20">
                    <Grid>
                        <!-- Empty State -->
                        <controls:EmptyStateControl 
                            IconText="&#xE787;"
                            Title="No installments yet"
                            Message="Define a schedule to generate installments for this obligation."
                            ActionText="Define Schedule"
                            ActionCommand="{Binding DefineScheduleCommand}"
                            IsActionVisible="True"
                            Visibility="{Binding Installments.Count, Converter={StaticResource CollectionEmptyToVisibility}}"/>

                        <!-- Installments Grid -->
                        <DataGrid ItemsSource="{Binding Installments}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowBackground="{DynamicResource App.GridRowBrush}"
                                  AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                                  Foreground="{DynamicResource App.TextPrimaryBrush}"
                                  Visibility="{Binding Installments.Count, Converter={StaticResource CollectionNotEmptyToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateDisplay}" Width="100"/>
                                <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedAmount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingAmount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90"/>
                                <DataGridTextColumn Header="Days Overdue" Binding="{Binding DaysOverdue}" Width="90"/>
                                <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Payments Tab -->
            <TabItem Header="Payments" Foreground="{DynamicResource App.TextPrimaryBrush}">
                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="0,12,12,12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Filter Bar -->
                        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Date Range -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="From:" 
                                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <DatePicker SelectedDate="{Binding PaymentsFromDate}"
                                                Width="100"
                                                FontSize="12"/>
                                    <TextBlock Text="To:" 
                                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,6,0"/>
                                    <DatePicker SelectedDate="{Binding PaymentsToDate}"
                                                Width="100"
                                                FontSize="12"/>
                                </StackPanel>

                                <!-- Search -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                    <TextBox Text="{Binding PaymentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Width="150"
                                             FontSize="12"
                                             Padding="8,6"
                                             Background="{DynamicResource App.InputBackgroundBrush}"
                                             Foreground="{DynamicResource App.InputForegroundBrush}"
                                             BorderBrush="{DynamicResource App.InputBorderBrush}"/>
                                </StackPanel>

                                <!-- Show Reversals Toggle -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding ShowReversals}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Show Reversals" 
                                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"/>
                                </StackPanel>

                                <!-- Refresh -->
                                <Button Grid.Column="4" 
                                        Content="Refresh" 
                                        Command="{Binding RefreshPaymentsCommand}"
                                        Padding="12,6"
                                        Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Payments Content -->
                        <Grid Grid.Row="1" Grid.Column="0">
                            <!-- Empty State -->
                            <controls:EmptyStateControl 
                                IconText="&#xE8C7;"
                                Title="No payments recorded"
                                Message="Record a payment to see it here."
                                ActionText="Record Payment"
                                ActionCommand="{Binding RecordPaymentCommand}"
                                IsActionVisible="True"
                                Visibility="{Binding HasNoPayments, Converter={StaticResource BoolToVis}}"/>

                            <!-- Payments Grid -->
                            <DataGrid ItemsSource="{Binding PaymentsView}"
                                      SelectedItem="{Binding SelectedPayment}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowBackground="{DynamicResource App.GridRowBrush}"
                                      AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                                      Foreground="{DynamicResource App.TextPrimaryBrush}"
                                      SelectionMode="Single"
                                      Visibility="{Binding HasPayments, Converter={StaticResource BoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDateDisplay}" Width="100"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                                    <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                                    <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="*" MinWidth="100"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Payment Details Panel -->
                        <Border Grid.Row="1" Grid.Column="1" 
                                Background="{DynamicResource App.SurfaceAltBrush}" 
                                CornerRadius="12" 
                                Padding="16"
                                Margin="16,0,0,0"
                                Width="300"
                                Visibility="{Binding HasSelectedPayment, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Payment Details" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.TextPrimaryBrush}"
                                               Margin="0,0,0,12"/>

                                    <!-- Amount -->
                                    <TextBlock Text="AMOUNT" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Margin="0,2,0,10">
                                        <Run Text="{Binding SelectedPayment.Amount, StringFormat=N2}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding SelectedPayment.CurrencyCode}" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    </TextBlock>

                                    <!-- Date -->
                                    <TextBlock Text="DATE" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SelectedPayment.EffectiveDateDisplay}" 
                                               FontSize="13" 
                                               Margin="0,2,0,10"/>

                                    <!-- Reference -->
                                    <TextBlock Text="REFERENCE" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SelectedPayment.Reference, TargetNullValue='-'}" 
                                               FontSize="13" 
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,10"/>

                                    <!-- Status -->
                                    <TextBlock Text="STATUS" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SelectedPayment.StatusDisplay}" 
                                               FontSize="13" 
                                               Margin="0,2,0,10"/>

                                    <!-- Reversal Info (if reversal) -->
                                    <StackPanel Visibility="{Binding SelectedPaymentIsReversal, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="REVERSAL REASON" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding SelectedPayment.Reason}" 
                                                   FontSize="13" 
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource App.WarningBrush}"
                                                   Margin="0,2,0,10"/>
                                    </StackPanel>

                                    <!-- Allocations -->
                                    <TextBlock Text="ALLOCATIONS" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,4"/>
                                    <ItemsControl ItemsSource="{Binding SelectedPaymentAllocations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="4" Padding="8" Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding InstallmentKey}" 
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" FontSize="11">
                                                            <Run Text="{Binding Amount, StringFormat=N2}"/>
                                                            <Run Text=" "/>
                                                            <Run Text="{Binding CurrencyCode}" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Reverse Button (only for non-reversed payments) -->
                                    <Button Content="Reverse Payment"
                                            Command="{Binding ReverseSelectedPaymentCommand}"
                                            Margin="0,16,0,0"
                                            Padding="12,8"
                                            Background="{DynamicResource App.DangerBrush}"
                                            Foreground="White"
                                            Visibility="{Binding CanReverseSelected, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Already Reversed Notice -->
                                    <Border Background="{DynamicResource App.DangerSurfaceBrush}" CornerRadius="6" Padding="10" Margin="0,16,0,0"
                                            Visibility="{Binding SelectedPaymentIsReversed, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="This payment has been reversed" 
                                                   FontSize="12"
                                                   Foreground="{DynamicResource App.WarningBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <!-- Reversal Confirmation -->
                                    <Border Background="{DynamicResource App.DangerSurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,12,0,0"
                                            Visibility="{Binding IsReversalConfirmationVisible, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Confirm Reversal" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="This will reverse the payment and its allocations. This action cannot be undone."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,12"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Confirm" 
                                                        Command="{Binding ConfirmReversalCommand}"
                                                        Background="{DynamicResource App.DangerBrush}"
                                                        Foreground="White"
                                                        Padding="12,6"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="Cancel" 
                                                        Command="{Binding CancelReversalCommand}"
                                                        Padding="12,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Reversing Indicator -->
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                                Visibility="{Binding IsReversing, Converter={StaticResource BoolToVis}}">
                                        <ProgressBar IsIndeterminate="True" Width="60" Height="3" Margin="0,0,8,0"/>
                                        <TextBlock Text="Reversing..." 
                                                   FontSize="12" 
                                                   Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Audit Tab -->
            <TabItem Header="Audit Trail" Foreground="{DynamicResource App.TextPrimaryBrush}">
                <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="0,12,12,12" Padding="20">
                    <Grid>
                        <!-- Empty State -->
                        <controls:EmptyStateControl 
                            IconText="&#xE81C;"
                            Title="No history yet"
                            Message="Actions will appear here once events are recorded."
                            IsActionVisible="False"
                            Visibility="{Binding AuditEntries.Count, Converter={StaticResource CollectionEmptyToVisibility}}"/>

                        <!-- Audit Grid -->
                        <DataGrid ItemsSource="{Binding AuditEntries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowBackground="{DynamicResource App.GridRowBrush}"
                                  AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                                  Foreground="{DynamicResource App.TextPrimaryBrush}"
                                  Visibility="{Binding AuditEntries.Count, Converter={StaticResource CollectionNotEmptyToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampDisplay}" Width="130"/>
                                <DataGridTextColumn Header="Effective Date" Binding="{Binding EffectiveDateDisplay}" Width="100"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4" 
                Background="{DynamicResource App.OverlayBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Loading..." 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

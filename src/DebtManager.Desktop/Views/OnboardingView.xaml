<UserControl x:Class="DebtManager.Desktop.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{DynamicResource App.SurfaceBrush}"
                CornerRadius="16"
                MaxWidth="560"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40"
                Margin="40">
            <StackPanel>
                <!-- Step Indicator -->
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           Margin="0,0,0,8">
                    <Run Text="Step "/>
                    <Run Text="{Binding CurrentStepIndex, Mode=OneWay, StringFormat='{}{0}'}" /><Run Text=""/>
                    <!-- We display 1-based index via converter-free approach -->
                </TextBlock>

                <!-- We'll use a simpler approach: just show "Step X of Y" -->
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource App.AccentBrush}"
                           FontWeight="SemiBold"
                           Margin="0,-28,0,8"
                           Visibility="Collapsed"/>

                <!-- Re-do step indicator cleanly -->
                <StackPanel Orientation="Horizontal" Margin="0,-28,0,12">
                    <TextBlock FontSize="12" Foreground="{DynamicResource App.AccentBrush}" FontWeight="SemiBold">
                        <Run Text="STEP "/>
                    </TextBlock>
                    <!-- Show step numbers as dots -->
                    <ItemsControl Margin="4,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <!-- Step Title -->
                <TextBlock Text="{Binding StepTitle}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Step Description -->
                <TextBlock Text="{Binding StepDescription}"
                           FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <!-- Step 1: Welcome + Device ID -->
                <StackPanel Visibility="{Binding IsFirstStep, Converter={StaticResource BoolToVis}}">
                    <Border Background="{DynamicResource App.InputBackgroundBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="DEVICE ID" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding DeviceIdDisplay, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Style="{StaticResource FormInput}"/>
                            <TextBlock Text="This uniquely identifies your device for sync-safe operations. It is stored locally and never changes."
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 2: Defaults -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Currency -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="DEFAULT CURRENCY" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                                  Text="{Binding DefaultCurrencyCode, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Style="{StaticResource FormComboBox}"/>
                        <TextBlock Text="{Binding CurrencyError}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding CurrencyError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="3-letter currency code used for new obligations"
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <!-- Timezone -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="DEFAULT TIMEZONE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableTimezones}"
                                  Text="{Binding DefaultTimeZone, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Style="{StaticResource FormComboBox}"/>
                        <TextBlock Text="{Binding TimeZoneError}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding TimeZoneError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="IANA timezone for schedule calculations"
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <!-- Require App Unlock -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox IsChecked="{Binding RequireAppUnlock}" VerticalAlignment="Center"/>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Require app unlock"
                                       FontSize="14"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            <TextBlock Text="Require authentication when app starts (coming soon)"
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Step 3: Cloud Sync -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Base URL -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="SYNC SERVER URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SyncBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}"/>
                        <TextBlock Text="{Binding SyncBaseUrlError}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding SyncBaseUrlError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="Example: https://sync.example.com"
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <!-- API Key -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="API KEY" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SyncApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}"/>
                        <TextBlock Text="{Binding SyncApiKeyError}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding SyncApiKeyError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="Your sync authentication key"
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <!-- Vault ID -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="VAULT ID (OPTIONAL)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SyncVaultId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}"/>
                        <TextBlock Text="{Binding SyncVaultIdError}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding SyncVaultIdError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="Leave empty to use your device ID as the vault"
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Overall Status -->
                <TextBlock Text="{Binding OverallStatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource App.DangerBrush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding OverallStatusText, Converter={StaticResource NullToCollapsed}}"/>

                <!-- Busy indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="2"
                             Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                <!-- Navigation Buttons -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back -->
                    <Button Grid.Column="0"
                            Content="Back"
                            Command="{Binding BackCommand}"
                            Padding="16,10"
                            Visibility="{Binding CanBack, Converter={StaticResource BoolToVis}}"/>

                    <!-- Skip for now (always visible) -->
                    <Button Grid.Column="2"
                            Content="Skip for now"
                            Command="{Binding SkipCommand}"
                            Padding="16,10"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="{DynamicResource App.TextSecondaryBrush}"/>

                    <!-- Next (steps 1-2) -->
                    <Button Grid.Column="3"
                            Content="Next"
                            Command="{Binding NextCommand}"
                            Padding="20,10"
                            Background="{DynamicResource App.AccentBrush}"
                            Foreground="White"
                            FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Finish (last step only) -->
                    <Button Grid.Column="3"
                            Content="Finish Setup"
                            Command="{Binding FinishCommand}"
                            Padding="20,10"
                            FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Background" Value="{DynamicResource App.SuccessBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

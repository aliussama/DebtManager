<UserControl x:Class="DebtManager.Desktop.Views.PaymentsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             xmlns:behaviors="clr-namespace:DebtManager.Desktop.Behaviors"
             xmlns:services="clr-namespace:DebtManager.Desktop.Services"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Payments Ledger" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Export CSV" 
                        Command="{Binding ExportCsvCommand}"
                        Padding="12,8"
                        Margin="0,0,8,0"/>
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Padding="12,8"
                        Margin="0,0,8,0"/>
                <Button Content="+ Record Payment" 
                        Command="{Binding RecordPaymentCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Grid>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Obligation Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Obligation:" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Obligations}"
                              SelectedItem="{Binding SelectedObligation}"
                              DisplayMemberPath="Name"
                              Width="180"
                              FontSize="13"
                              Padding="8,6"/>
                </StackPanel>

                <!-- Date Range -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBlock Text="From:" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FromDate}"
                                Width="110"
                                FontSize="12"/>
                    <TextBlock Text="To:" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,6,0"/>
                    <DatePicker SelectedDate="{Binding ToDate}"
                                Width="110"
                                FontSize="12"/>
                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="180"
                             FontSize="13"
                             Padding="8,6"
                             Tag="Search reference..."
                             behaviors:FocusOnRequestBehavior.FocusKey="{x:Static services:FocusTargets.PaymentsSearch}"
                             behaviors:FocusOnRequestBehavior.FocusService="{DynamicResource FocusService}"/>
                </StackPanel>

                <!-- Show Reversals Toggle -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding ShowReversals}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Show Reversals" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Payments Grid -->
            <Border Grid.Column="0" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <!-- Empty State -->
                    <controls:EmptyStateControl 
                        IconText="&#xE8C7;"
                        Title="No payments recorded"
                        Message="Once you record payments against your obligations, they will appear here for easy tracking and history."
                        ActionText="Record Payment"
                        ActionCommand="{Binding RecordPaymentCommand}"
                        IsActionVisible="True"
                        Visibility="{Binding HasNoPayments, Converter={StaticResource BoolToVis}}"/>

                    <!-- Data Grid -->
                    <DataGrid ItemsSource="{Binding ItemsView}"
                              SelectedItem="{Binding SelectedPayment}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="{DynamicResource App.GridRowBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}"
                              SelectionMode="Single"
                              Visibility="{Binding HasPayments, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDateDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Obligation" Binding="{Binding ObligationName}" Width="*" MinWidth="150"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                            <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="150"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="80"/>
                            <DataGridTemplateColumn Header="Actions" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Reverse" 
                                                Command="{Binding DataContext.ReverseSelectedPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButton}"
                                                ToolTip="Reverse this payment"
                                                Visibility="{Binding IsReversal, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Details Panel -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="16,0,0,0"
                    Width="320"
                    Visibility="{Binding HasSelectedPayment, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Payment Details" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- Basic Info -->
                        <TextBlock Text="AMOUNT" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock FontSize="24" FontWeight="Bold" Margin="0,4,0,12">
                            <Run Text="{Binding SelectedPayment.Amount, StringFormat=N2}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SelectedPayment.CurrencyCode}" FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        </TextBlock>

                        <TextBlock Text="DATE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedPayment.EffectiveDateDisplay}" 
                                   FontSize="14" 
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="OBLIGATION" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedPayment.ObligationName}" 
                                   FontSize="14" 
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="REFERENCE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedPayment.Reference, TargetNullValue='-'}" 
                                   FontSize="14" 
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="STATUS" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedPayment.StatusDisplay}" 
                                   FontSize="14" 
                                   Margin="0,4,0,12"/>

                        <!-- Reversal Info (if reversal) -->
                        <StackPanel Visibility="{Binding SelectedPayment.IsReversal, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="REVERSAL REASON" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding SelectedPayment.Reason}" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource App.WarningBrush}"
                                       Margin="0,4,0,12"/>
                        </StackPanel>

                        <!-- Allocations -->
                        <TextBlock Text="ALLOCATIONS" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,8,0,4"/>
                        <ItemsControl ItemsSource="{Binding SelectedPayment.Allocations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="4" Padding="8" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding InstallmentKey}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" FontSize="12">
                                                <Run Text="{Binding Amount, StringFormat=N2}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding CurrencyCode}" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Reverse Button -->
                        <Button Content="Reverse Payment"
                                Command="{Binding ReverseSelectedPaymentCommand}"
                                CommandParameter="{Binding SelectedPayment}"
                                Margin="0,20,0,0"
                                Padding="16,10"
                                Background="{DynamicResource App.DangerBrush}"
                                Foreground="White"
                                Visibility="{Binding CanReverseSelected, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4" 
                Background="{DynamicResource App.OverlayBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Loading..." 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="DebtManager.Desktop.Views.RecordPaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="800"
             Background="{DynamicResource App.SurfaceBrush}">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border CornerRadius="16" Padding="32">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Form -->
            <StackPanel Grid.Column="0">
                <!-- Header -->
                <TextBlock Text="Record Payment" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           Margin="0,0,0,24"/>

                <!-- Obligation Selection -->
                <TextBlock Text="OBLIGATION" Style="{StaticResource FormLabel}"/>
                <ComboBox ItemsSource="{Binding Obligations}" 
                          SelectedItem="{Binding SelectedObligation}"
                          Style="{StaticResource FormComboBox}"
                          DisplayMemberPath="Name"/>
                <TextBlock Text="" Style="{StaticResource ErrorText}"/>

                <!-- Amount Field -->
                <TextBlock Text="AMOUNT" Style="{StaticResource FormLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FormInput}"
                             Margin="0,0,8,4"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Currencies}" 
                              SelectedItem="{Binding CurrencyCode}"
                              Style="{StaticResource FormComboBox}"/>
                </Grid>
                <TextBlock Text="{Binding AmountError}" 
                           Style="{StaticResource ErrorText}"
                           Visibility="{Binding AmountError, Converter={StaticResource NullToCollapsed}}"/>

                <!-- Payment Date -->
                <TextBlock Text="PAYMENT DATE" Style="{StaticResource FormLabel}"/>
                <DatePicker SelectedDate="{Binding PaymentDate, Converter={StaticResource DateOnlyConverter}}"
                            Background="{DynamicResource App.InputBackgroundBrush}"
                            Foreground="{DynamicResource App.TextPrimaryBrush}"
                            BorderBrush="{DynamicResource App.InputBorderBrush}"
                            Padding="12,10"
                            Margin="0,0,0,16"/>

                <!-- Reference -->
                <TextBlock Text="REFERENCE / NOTES" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource FormInput}"
                         Height="60"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Style="{StaticResource ErrorText}"
                           FontWeight="SemiBold"
                           Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Cancel" 
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,0"/>
                    <Button Content="Record Payment" 
                            Command="{Binding RecordCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True" 
                             Height="3" 
                             Margin="0,16,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <!-- Separator -->
            <Rectangle Grid.Column="1" 
                       Width="1" 
                       Fill="{DynamicResource App.InputBorderBrush}"
                       Margin="24,0"/>

            <!-- Right Column: Allocation Preview -->
            <Border Grid.Column="2" Background="{DynamicResource App.GridAltRowBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Header -->
                    <StackPanel Grid.Row="0">
                        <Grid>
                            <TextBlock Text="Allocation Preview" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            <ProgressBar IsIndeterminate="True" 
                                         Height="2" 
                                         Width="80"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <TextBlock Text="See how your payment will be allocated across installments"
                                   FontSize="12"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   Margin="0,4,0,16"/>
                    </StackPanel>

                    <!-- Preview Error -->
                    <Border Grid.Row="1" 
                            Background="{DynamicResource App.DangerSurfaceBrush}" 
                            CornerRadius="8" 
                            Padding="12"
                            VerticalAlignment="Top"
                            Visibility="{Binding HasPreviewError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding PreviewError}" 
                                   Foreground="{DynamicResource App.DangerBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </Border>

                    <!-- No Schedule Message -->
                    <Border Grid.Row="1" 
                            VerticalAlignment="Top"
                            Visibility="{Binding ShowNoScheduleMessage, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x26A0;" FontSize="32" HorizontalAlignment="Center" Margin="0,20,0,8"/>
                            <TextBlock Text="No Schedule Defined" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Payment will be recorded as unapplied. Define a schedule first for proper allocation."
                                       FontSize="12"
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Preview Content -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <!-- Charges Preview (if any) -->
                            <StackPanel Visibility="{Binding PreviewCharges.Count, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="CHARGES" 
                                           FontSize="11" 
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource App.WarningBrush}"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding PreviewCharges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource App.InfoSurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding ChargeType}" 
                                                                   FontSize="13" 
                                                                   Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}">
                                                            <Run Text="Outstanding: "/>
                                                            <Run Text="{Binding OutstandingBefore, StringFormat=N2}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.SuccessBrush}">
                                                            <Run Text="-"/>
                                                            <Run Text="{Binding AllocatedNow, StringFormat=N2}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Rectangle Height="1" Fill="{DynamicResource App.InputBorderBrush}" Margin="0,8,0,12"/>
                            </StackPanel>

                            <!-- Installments Preview -->
                            <TextBlock Text="INSTALLMENTS" 
                                       FontSize="11" 
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding PreviewInstallments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="12" Margin="0,0,0,6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource App.InfoSurfaceBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WillReceiveAllocation}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource App.SuccessSurfaceBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Date and Status -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DueDateDisplay}" 
                                                               FontSize="13" 
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                                                    <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource App.BorderBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                                        <Setter Property="Background" Value="{DynamicResource App.SuccessSurfaceBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                                        <Setter Property="Background" Value="{DynamicResource App.SuccessSurfaceBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Overdue">
                                                                        <Setter Property="Background" Value="{DynamicResource App.DangerSurfaceBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <!-- Allocated Amount -->
                                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                                           FontSize="14" 
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           Visibility="{Binding WillReceiveAllocation, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.SuccessBrush}"/>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="-"/>
                                                    <Run Text="{Binding AllocatedNow, StringFormat=N2}"/>
                                                </TextBlock>
                                                
                                                <!-- Details Row -->
                                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}">
                                                        <Run Text="Due: "/>
                                                        <Run Text="{Binding InstallmentAmount, StringFormat=N0}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="12,0,0,0">
                                                        <Run Text="Paid: "/>
                                                        <Run Text="{Binding AlreadyPaid, StringFormat=N0}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="12,0,0,0">
                                                        <Run Text="After: "/>
                                                        <Run Text="{Binding OutstandingAfter, StringFormat=N0}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Unapplied Amount -->
                    <Border Grid.Row="2" 
                            Background="{DynamicResource App.AccentBrush}" 
                            CornerRadius="8" 
                            Padding="12"
                            Margin="0,12,0,0"
                            Visibility="{Binding PreviewUnappliedAmount, Converter={StaticResource DecimalToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Unapplied / Overpayment" 
                                           FontSize="13" 
                                           FontWeight="Medium"
                                           Foreground="White"/>
                                <TextBlock Text="Will be recorded as available credit"
                                           FontSize="11"
                                           Foreground="#FFFFFFAA"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding PreviewUnappliedAmount, StringFormat=N2}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding CurrencyCode}" FontSize="12"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

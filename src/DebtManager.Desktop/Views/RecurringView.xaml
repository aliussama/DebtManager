<UserControl x:Class="DebtManager.Desktop.Views.RecurringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             Background="{DynamicResource App.BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Recurring Transactions" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Manage recurring income and expense templates" FontSize="14" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Tag:" FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding TagSuggestions}"
                              SelectedItem="{Binding SelectedTagFilter}"
                              Width="130" FontSize="12" Padding="6,4"
                              Background="{DynamicResource App.InputBackgroundBrush}"
                              Foreground="{DynamicResource App.InputForegroundBrush}"/>
                </StackPanel>
                <Button Command="{Binding RefreshCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Refresh" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportCsvCommand}" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                        <TextBlock Text="Export" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New Recurring" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Create form -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12"
                Visibility="{Binding IsCreateVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Create Recurring Transaction" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="KIND" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding KindOptions}" SelectedItem="{Binding NewKind}" Width="100" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ACCOUNT" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableAccounts}" SelectedItem="{Binding NewAccount}" DisplayMemberPath="Name" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="AMOUNT" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Width="100" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="REFERENCE" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewReference, UpdateSourceTrigger=PropertyChanged}" Width="140" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="FREQUENCY" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FrequencyOptions}" SelectedItem="{Binding NewFrequency}" Width="110" Padding="10,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="10">
                        <TextBlock Text="START" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding NewStartDate}" Width="130" FontSize="12"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCreateCommand}" Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Create" Command="{Binding ConfirmCreateCommand}" Background="{DynamicResource App.AccentBrush}" Foreground="White" Padding="16,8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Items List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}">
                                            <Run Text="{Binding Reference, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Background="{DynamicResource App.SurfaceAltBrush}">
                                            <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource App.TextMutedBrush}" Margin="0,2,0,0">
                                        <Run Text="{Binding Frequency, Mode=OneWay}"/>
                                        <Run Text=" | Next: "/>
                                        <Run Text="{Binding NextDueDate, Mode=OneWay, StringFormat=yyyy-MM-dd}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="12,0"
                                           Foreground="{DynamicResource App.TextPrimaryBrush}">
                                    <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                    <Run Text=" " FontSize="11"/><Run Text="{Binding CurrencyCode, Mode=OneWay}" FontSize="11" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                </TextBlock>
                                <Border Grid.Column="2" CornerRadius="4" Padding="8,3" Margin="4,0" VerticalAlignment="Center"
                                        Background="{DynamicResource App.SurfaceAltBrush}">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="3" VerticalAlignment="Center" Padding="8,6" Margin="4,0" ToolTip="Post Now"
                                        Command="{Binding DataContext.PostNowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource App.SuccessBrush}" Foreground="White">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                                <Button Grid.Column="4" VerticalAlignment="Center" Padding="8,6" Margin="4,0" ToolTip="Archive"
                                        Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <controls:EmptyStateControl Grid.Row="2"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                    Title="No Recurring Transactions"
                                    Message="Create recurring templates for salary, rent, subscriptions, etc."
                                    IconText="&#xE787;"
                                    ActionText="Create Recurring"
                                    ActionCommand="{Binding ShowCreateCommand}"/>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>

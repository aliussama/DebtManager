<UserControl x:Class="DebtManager.Desktop.Views.RetirementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource App.BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Retirement Planning"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Define your retirement profile and assumptions, then run a plan to assess readiness."
                           FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Profile Section -->
            <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Retirement Profile" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Retirement Date" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <DatePicker SelectedDate="{Binding RetirementDate}" Width="130"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Monthly Spending" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding DesiredMonthlySpending, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Currency" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding SpendingCurrency, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Life Expectancy" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding LifeExpectancyYears, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="SWR" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding SafeWithdrawalRate, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        </StackPanel>
                        <Button Content="Save Profile" Command="{Binding SaveProfileCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" Margin="0,12,0,0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Assumptions Section -->
            <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Planning Assumptions" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Return Rate" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ExpectedReturnRate, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Inflation Rate" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ExpectedInflation, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Salary Growth" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ExpectedSalaryGrowth, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Monthly Savings" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding MonthlySavings, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Text="Report CCY" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ReportingCurrency, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        </StackPanel>
                        <Button Content="Save Assumptions" Command="{Binding SaveAssumptionsCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" Margin="0,12,8,0"/>
                        <Button Content="Run Plan" Command="{Binding RunPlanCommand}" Style="{StaticResource SuccessButton}" Padding="12,6" Margin="0,12,8,0"/>
                        <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Padding="12,6" Margin="0,12,0,0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Error / Empty State -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}"
                       FontSize="13" Foreground="{DynamicResource App.DangerBrush}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"
                       Margin="0,0,0,12" TextWrapping="Wrap"/>

            <!-- Results Section -->
            <Border Grid.Row="4" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Retirement Plan Results" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Years to Retirement" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.YearsToRetirement, StringFormat={}{0:F1}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Required Corpus" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.RequiredCorpusAtRetirement, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Projected Corpus" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.ProjectedCorpusAtRetirement, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.SuccessBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Funding Gap" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.FundingGap, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.DangerBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Required Monthly Savings" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.RequiredMonthlySavings, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.AccentBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource App.BackgroundBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,12,8" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="Monthly Spending @ Retirement" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                <TextBlock Text="{Binding Plan.MonthlySpendingAtRetirementInflationAdjusted, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Warnings -->
            <ItemsControl Grid.Row="5" ItemsSource="{Binding Warnings}" Margin="0,0,0,12"
                          Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource App.WarningBrush}" Margin="0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Loading Overlay (placed as a Grid child covering all rows is the pattern, but using a simpler approach here) -->
        </Grid>
    </ScrollViewer>
</UserControl>

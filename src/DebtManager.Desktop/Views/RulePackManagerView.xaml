<UserControl x:Class="DebtManager.Desktop.Views.RulePackManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.ButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Rule Pack Manager" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>
                <Button Content="Install Sample Packs" 
                        Command="{Binding InstallSamplePacksCommand}"
                        Style="{StaticResource ActionButton}"/>
            </StackPanel>
        </Grid>

        <!-- Assignment Section -->
        <Border Grid.Row="1" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Obligation Selection -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SELECT OBLIGATION" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Obligations}"
                              SelectedItem="{Binding SelectedObligation}"
                              DisplayMemberPath="Name"
                              FontSize="14"
                              Padding="10,8"/>
                    <TextBlock Text="{Binding CurrentAssignmentText}" 
                               FontSize="11"
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Rule Pack Selection -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SELECT RULE PACK" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding RulePacks}"
                              SelectedItem="{Binding SelectedRulePack}"
                              FontSize="14"
                              Padding="10,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Effective Date:" 
                                   FontSize="11"
                                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding EffectiveDate, Converter={StaticResource DateOnlyConverter}}"
                                    FontSize="11"
                                    Width="120"/>
                    </StackPanel>
                </StackPanel>

                <!-- Assign Button -->
                <Button Grid.Column="4" 
                        Content="Assign Pack"
                        Command="{Binding AssignRulePackCommand}"
                        Style="{StaticResource ActionButton}"
                        VerticalAlignment="Top"
                        Margin="0,20,0,0"/>
            </Grid>
        </Border>

        <!-- Installed Rule Packs -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="20">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" 
                           Text="Installed Rule Packs" 
                           Style="{StaticResource SectionHeader}"/>

                <Grid>
                    <!-- Empty State -->
                    <controls:EmptyStateControl 
                        IconText="&#xE71C;"
                        Title="No rule packs installed"
                        Message="Install sample rule packs to get started with grace periods, penalties, and interest rules."
                        ActionText="Install Sample Packs"
                        ActionCommand="{Binding InstallSamplePacksCommand}"
                        IsActionVisible="True"
                        Visibility="{Binding HasNoRulePacks, Converter={StaticResource BoolToVis}}"/>

                    <!-- Rule Packs Grid -->
                    <DataGrid ItemsSource="{Binding RulePacks}"
                              SelectedItem="{Binding SelectedRulePack}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="{DynamicResource App.GridRowBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridAltRowBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}"
                              SelectionMode="Single"
                              Visibility="{Binding HasRulePacks, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Pack ID" Binding="{Binding PackId}" Width="150"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding VersionLabel}" Width="80"/>
                            <DataGridTextColumn Header="Effective From" Binding="{Binding EffectiveFromDisplay}" Width="110"/>
                            <DataGridTextColumn Header="Rules" Binding="{Binding RulesCount}" Width="60"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4" 
                Background="{DynamicResource App.OverlayBrush}" 
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Processing..." 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

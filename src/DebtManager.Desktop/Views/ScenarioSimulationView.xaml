<UserControl x:Class="DebtManager.Desktop.Views.ScenarioSimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DebtManager.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="{DynamicResource App.BackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Scenario Simulation" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                    <TextBlock Text="Simulate what-if scenarios without modifying actual data" 
                               FontSize="13" 
                               Foreground="{DynamicResource App.TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Configuration Section -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="CONFIGURATION" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource App.TextMutedBrush}"
                               Margin="0,0,0,12"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Obligation Selection -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Obligation" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Obligations}"
                                      SelectedItem="{Binding SelectedObligation}"
                                      DisplayMemberPath="Name"
                                      MinWidth="200"/>
                        </StackPanel>
                        
                        <!-- As-Of Date -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="As-Of Date" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding AsOfDate}"/>
                        </StackPanel>
                        
                        <!-- Horizon End Date -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Horizon End Date" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding HorizonEndDate}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hypotheses Section -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="HYPOTHESES" 
                                   FontSize="11" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <Button Grid.Column="1" 
                                Content="+ Add Hypothesis" 
                                Command="{Binding AddHypothesisCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="12,6"
                                Margin="0,0,8,0"/>
                        
                        <Button Grid.Column="2" 
                                Content="Run Simulation" 
                                Command="{Binding RunSimulationCommand}"
                                Style="{StaticResource SuccessButton}"
                                Padding="16,6"
                                IsEnabled="{Binding HasSelectedObligation}"/>
                    </Grid>

                    <!-- Hypotheses list -->
                    <ItemsControl ItemsSource="{Binding Hypotheses}" 
                                  Visibility="{Binding HasHypotheses, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource App.SurfaceAltBrush}" 
                                        CornerRadius="8" 
                                        Padding="12" 
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Hypothesis Type -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Type" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                            <ComboBox ItemsSource="{Binding DataContext.HypothesisTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding Type}"
                                                      Width="130"/>
                                        </StackPanel>
                                        
                                        <!-- Dynamic fields based on type -->
                                        <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            
                                            <!-- Effective Date (all types) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="120">
                                                <TextBlock Text="Effective Date" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <DatePicker SelectedDate="{Binding EffectiveDate}" Width="120"/>
                                            </StackPanel>
                                            
                                            <!-- Amount (ExtraPayment, OneTimeExpense) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="100"
                                                        Visibility="{Binding ShowAmountFields, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="Amount" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                            </StackPanel>
                                            
                                            <!-- Currency (ExtraPayment, OneTimeExpense) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="60"
                                                        Visibility="{Binding ShowAmountFields, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="Currency" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <TextBox Text="{Binding CurrencyCode, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                            </StackPanel>
                                            
                                            <!-- Payment Reference Filter (MissPayment, DelayedPayment) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="140"
                                                        Visibility="{Binding ShowPaymentReferenceField, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="Payment Ref Contains" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <TextBox Text="{Binding PaymentReferenceContains, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                                            </StackPanel>
                                            
                                            <!-- New Effective Date (DelayedPayment) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="120"
                                                        Visibility="{Binding ShowNewEffectiveDateField, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="New Date" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <DatePicker SelectedDate="{Binding NewEffectiveDate}" Width="120"/>
                                            </StackPanel>
                                            
                                            <!-- Reference (optional) -->
                                            <StackPanel Margin="0,0,12,0" MinWidth="150">
                                                <TextBlock Text="Reference (optional)" FontSize="10" Foreground="{DynamicResource App.TextMutedBrush}"/>
                                                <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                            </StackPanel>
                                        </WrapPanel>
                                        
                                        <!-- Remove button -->
                                        <Button Grid.Column="2" 
                                                Content="X" 
                                                Command="{Binding DataContext.RemoveHypothesisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"
                                                FontSize="12"
                                                Background="Transparent"
                                                Foreground="{DynamicResource App.DangerBrush}"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Empty state for hypotheses -->
                    <controls:EmptyStateControl 
                        Visibility="{Binding HasHypotheses, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                        IconText="&#x1F4DD;"
                        Title="No hypotheses defined"
                        Message="Add hypotheses to simulate different scenarios"
                        ActionText="Add Hypothesis"
                        ActionCommand="{Binding AddHypothesisCommand}"/>
                </StackPanel>
            </Border>

            <!-- Results Section -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource App.SurfaceBrush}" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,0,16"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="RESULTS" 
                                   FontSize="11" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Export CSV" 
                                    Command="{Binding ExportCsvCommand}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"/>
                            <Button Content="Clear Results" 
                                    Command="{Binding ClearResultsCommand}"
                                    Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Summary Cards -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Baseline Card -->
                        <Border Grid.Column="0" 
                                Background="{DynamicResource App.SurfaceAltBrush}" 
                                CornerRadius="10" 
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="BASELINE" 
                                           FontSize="12" 
                                           FontWeight="SemiBold" 
                                           Foreground="{DynamicResource App.AccentBrush}"
                                           Margin="0,0,0,12"/>
                                
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Total Payments" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="{Binding BaselineTotalPayments, StringFormat='{}{0:N2}'}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                    
                                    <TextBlock Grid.Row="1" Text="Charges Count" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Text="{Binding BaselineChargesCount}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,8,0,0"/>
                                    
                                    <TextBlock Grid.Row="2" Text="Overdue Installments" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" 
                                               Text="{Binding BaselineOverdueInstallments}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Scenario Card -->
                        <Border Grid.Column="2" 
                                Background="{DynamicResource App.SurfaceAltBrush}" 
                                CornerRadius="10" 
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="SCENARIO" 
                                           FontSize="12" 
                                           FontWeight="SemiBold" 
                                           Foreground="{DynamicResource App.SuccessBrush}"
                                           Margin="0,0,0,12"/>
                                
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Total Payments" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="{Binding ScenarioTotalPayments, StringFormat='{}{0:N2}'}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                    
                                    <TextBlock Grid.Row="1" Text="Charges Count" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Text="{Binding ScenarioChargesCount}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,8,0,0"/>
                                    
                                    <TextBlock Grid.Row="2" Text="Overdue Installments" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" 
                                               Text="{Binding ScenarioOverdueInstallments}" 
                                               Foreground="{DynamicResource App.TextPrimaryBrush}" 
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Deltas Summary -->
                    <Border Background="{DynamicResource App.SurfaceAltBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x0394;" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Installment Deltas: " Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding InstallmentDeltasCount}" 
                                       Foreground="{DynamicResource App.WarningBrush}" 
                                       FontWeight="Bold"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" installment(s) with differences" Foreground="{DynamicResource App.TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Deltas DataGrid -->
                    <DataGrid ItemsSource="{Binding Deltas}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="{DynamicResource App.SurfaceAltBrush}"
                              AlternatingRowBackground="{DynamicResource App.GridRowHoverBrush}"
                              MaxHeight="300"
                              Visibility="{Binding HasDeltas, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Installment" Binding="{Binding InstallmentKeyDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Baseline Outstanding" Binding="{Binding BaselineOutstanding, StringFormat='{}{0:N2}'}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Scenario Outstanding" Binding="{Binding ScenarioOutstanding, StringFormat='{}{0:N2}'}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Delta" Binding="{Binding DeltaDisplay}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPositiveDelta}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsNegativeDelta}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource App.SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Empty state for deltas -->
                    <controls:EmptyStateControl 
                        Visibility="{Binding HasDeltas, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                        IconText="&#x2714;"
                        Title="No differences found"
                        Message="The scenario produces the same installment outcomes as the baseline"
                        IsActionVisible="False"/>
                </StackPanel>
            </Border>

            <!-- Empty State when no obligation selected -->
            <Border Grid.Row="4"
                    Visibility="{Binding HasSelectedObligation, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                    Margin="0,20,0,0">
                <controls:EmptyStateControl 
                    IconText="&#x1F4CB;"
                    Title="Select an obligation to begin"
                    Message="Choose an obligation from the dropdown above to simulate different scenarios"
                    IsActionVisible="False"/>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.RowSpan="5"
                    Background="{DynamicResource App.HeavyOverlayBrush}"
                    CornerRadius="12"
                    Visibility="{Binding IsSimulating, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                    <TextBlock Text="Running simulation..." 
                               Foreground="{DynamicResource App.TextPrimaryBrush}"
                               FontSize="14"
                               Margin="0,16,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

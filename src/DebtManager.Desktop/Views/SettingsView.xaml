<UserControl x:Class="DebtManager.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800"
             Background="{DynamicResource App.BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource App.DangerBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource App.InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Settings" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                <TextBlock Text="Configure your application preferences" 
                           FontSize="13"
                           Foreground="{DynamicResource App.TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- General Settings Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="General" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Currency -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DEFAULT CURRENCY" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                                      Text="{Binding DefaultCurrencyCode, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Style="{StaticResource FormComboBox}"/>
                            <TextBlock Text="{Binding CurrencyError}" 
                                       Style="{StaticResource ErrorText}"
                                       Visibility="{Binding CurrencyError, Converter={StaticResource NullToCollapsed}}"/>
                            <TextBlock Text="Used for new obligations and payments" 
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>

                        <!-- Timezone -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DEFAULT TIMEZONE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableTimezones}"
                                      Text="{Binding DefaultTimeZone, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Style="{StaticResource FormComboBox}"/>
                            <TextBlock Text="{Binding TimezoneError}" 
                                       Style="{StaticResource ErrorText}"
                                       Visibility="{Binding TimezoneError, Converter={StaticResource NullToCollapsed}}"/>
                            <TextBlock Text="Used for schedule calculations" 
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Sync Settings Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Cloud Sync" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <TextBlock Text="Connect to a sync server to keep your data synchronized across devices." 
                               Style="{StaticResource FieldHint}"
                               Margin="0,0,0,16"/>

                    <!-- Base URL -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="SYNC SERVER URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SyncBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}"/>
                        <TextBlock Text="{Binding SyncBaseUrlError}" 
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding SyncBaseUrlError, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="Example: https://sync.example.com" 
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- API Key -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="API KEY" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SyncApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}"/>
                            <TextBlock Text="{Binding SyncApiKeyError}" 
                                       Style="{StaticResource ErrorText}"
                                       Visibility="{Binding SyncApiKeyError, Converter={StaticResource NullToCollapsed}}"/>
                            <TextBlock Text="Your sync authentication key" 
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>

                        <!-- Vault ID -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="VAULT ID (OPTIONAL)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SyncVaultId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}"/>
                            <TextBlock Text="{Binding SyncVaultIdError}" 
                                       Style="{StaticResource ErrorText}"
                                       Visibility="{Binding SyncVaultIdError, Converter={StaticResource NullToCollapsed}}"/>
                            <TextBlock Text="Leave empty to use device ID" 
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Security Settings Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Security" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding RequireAppUnlock}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Require app unlock" 
                                       FontSize="14"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                            <TextBlock Text="Coming soon - Require authentication when app starts" 
                                       Style="{StaticResource FieldHint}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Appearance Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="THEME" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Style="{StaticResource FormComboBox}"
                                  Width="200"
                                  HorizontalAlignment="Left"/>
                        <TextBlock Text="Switch between Dark and Light mode. Applied on save." 
                                   Style="{StaticResource FieldHint}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Backup & Restore Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <TextBlock Text="Export your entire vault as a single file, or restore from a previous backup. Restore will replace ALL current data." 
                               Style="{StaticResource FieldHint}"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Command="{Binding BackupCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,10"
                                Margin="0,0,12,0"
                                IsEnabled="{Binding IsBackupBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Backup Vault"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RestoreCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="16,10"
                                IsEnabled="{Binding IsRestoreBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Restore from Backup"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Busy indicators -->
                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,8"
                                 Visibility="{Binding IsBackupBusy, Converter={StaticResource BoolToVis}}"/>
                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,8"
                                 Visibility="{Binding IsRestoreBusy, Converter={StaticResource BoolToVis}}"/>

                    <!-- Restore Confirmation Panel -->
                    <Border Background="{DynamicResource App.DangerSurfaceBrush}" 
                            CornerRadius="8" 
                            Padding="16" 
                            Margin="0,4,0,0"
                            Visibility="{Binding IsRestoreConfirmVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Confirm Restore" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.DangerBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,4">
                                <Run Text="This will REPLACE all current data with the selected backup:"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedRestoreFilePath}" 
                                       FontSize="12"
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Yes, Restore" 
                                        Command="{Binding ConfirmRestoreCommand}"
                                        Background="{DynamicResource App.DangerBrush}"
                                        Foreground="White"
                                        Padding="16,8"
                                        Margin="0,0,12,0"/>
                                <Button Content="Cancel" 
                                        Command="{Binding CancelRestoreCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Data Management Section -->
            <Border Background="{DynamicResource App.SurfaceBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,12,0"/>
                        <TextBlock Text="Data Management" Style="{StaticResource SectionHeader}" Margin="0"/>
                    </StackPanel>

                    <TextBlock Text="Access your local data files and diagnostic logs. All data is stored on this device only."
                               Style="{StaticResource FieldHint}" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding OpenDataFolderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="16,10" Margin="0,0,12,0"
                                ToolTip="Open the folder where your vault database is stored"
                                AutomationProperties.Name="Open data folder">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Open Data Folder"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenLogsFolderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="16,10"
                                ToolTip="Open the diagnostic logs folder"
                                AutomationProperties.Name="Open logs folder">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Open Logs Folder"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <Border Background="{DynamicResource App.SurfaceAltBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,20"
                    Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="14"
                           Foreground="{DynamicResource App.TextPrimaryBrush}"/>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Run onboarding again"
                        Command="{Binding RunOnboardingCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"/>
                <Button Content="Reset to Defaults" 
                        Command="{Binding ResetDefaultsCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"/>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Save Settings"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Saving indicator -->
            <ProgressBar IsIndeterminate="True" 
                         Height="2" 
                         Margin="0,16,0,0"
                         Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

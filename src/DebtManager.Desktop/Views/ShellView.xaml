            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=IncomeSources}">
                <views:IncomeSourcesView DataContext="{Binding IncomeSourcesVm}"/>
            </Border>

            <!-- Help View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Help}">
                <views:HelpView DataContext="{Binding HelpVm}"/>
            </Border>

            <!-- Safe Mode Recovery Banner -->
            <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Background="{DynamicResource App.WarningBrush}" Padding="12,8"
                    Visibility="{Binding IsSafeMode, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding RecoveryBannerMessage}" FontSize="12" 
                               Foreground="Black" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="1" Content="Open Logs" Command="{Binding OpenLogsFolderCommand}"
                            Padding="8,4" FontSize="11" Margin="8,0" Background="White" Foreground="Black"
                            ToolTip="Open diagnostic logs folder"/>
                    <Button Grid.Column="2" Content="Exit Safe Mode" Command="{Binding ExitSafeModeCommand}"
                            Padding="8,4" FontSize="11" Background="White" Foreground="Black"
                            ToolTip="Resume normal operation"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Modal Overlay for Create Obligation Dialog -->
        <Border Grid.ColumnSpan="2" 
                Background="{DynamicResource App.OverlayBrush}"
                Visibility="{Binding ShowCreateObligationDialog, Converter={StaticResource BoolToVisibility}}"
                MouseDown="DialogOverlay_MouseDown">
            <Grid>
                <!-- Click outside to close -->
                <Border Background="Transparent" 
                        MouseDown="CloseDialogOverlay_Click"/>
                
                <!-- Dialog Container -->
                <Border Background="{DynamicResource App.SurfaceBrush}" 
                        CornerRadius="16"
                        MaxWidth="500"
                        MaxHeight="660"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Close Button -->
                        <Button Command="{Binding CloseDialogCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,12,0"
                                Padding="6"
                                Background="Transparent"
                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                Panel.ZIndex="10"
                                ToolTip="Close (Esc)">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                        
                        <!-- Dialog Content -->
                        <views:CreateObligationView DataContext="{Binding CreateObligationVm}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Modal Overlay for Record Payment Dialog -->
        <Border Grid.ColumnSpan="2" 
                Background="{DynamicResource App.OverlayBrush}"
                Visibility="{Binding ShowRecordPaymentDialog, Converter={StaticResource BoolToVisibility}}"
                MouseDown="DialogOverlay_MouseDown">
            <Grid>
                <!-- Click outside to close -->
                <Border Background="Transparent" 
                        MouseDown="CloseDialogOverlay_Click"/>
                
                <!-- Dialog Container -->
                <Border Background="{DynamicResource App.SurfaceBrush}" 
                        CornerRadius="16"
                        MaxWidth="860"
                        MaxHeight="680"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Close Button -->
                        <Button Command="{Binding CloseDialogCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,12,0"
                                Padding="6"
                                Background="Transparent"
                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                Panel.ZIndex="10"
                                ToolTip="Close (Esc)">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                        
                        <!-- Dialog Content -->
                        <views:RecordPaymentView DataContext="{Binding RecordPaymentVm}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Modal Overlay for Define Schedule Dialog -->
        <Border Grid.ColumnSpan="2" 
                Background="{DynamicResource App.OverlayBrush}"
                Visibility="{Binding ShowDefineScheduleDialog, Converter={StaticResource BoolToVisibility}}"
                MouseDown="DialogOverlay_MouseDown">
            <Grid>
                <!-- Click outside to close -->
                <Border Background="Transparent" 
                        MouseDown="CloseDialogOverlay_Click"/>
                
                <!-- Dialog Container -->
                <Border Background="{DynamicResource App.SurfaceBrush}" 
                        CornerRadius="16"
                        MaxWidth="540"
                        MaxHeight="700"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Close Button -->
                        <Button Command="{Binding CloseDialogCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,12,0"
                                Padding="6"
                                Background="Transparent"
                                Foreground="{DynamicResource App.TextSecondaryBrush}"
                                Panel.ZIndex="10"
                                ToolTip="Close (Esc)">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                        
                        <!-- Dialog Content -->
                        <views:DefineScheduleView DataContext="{Binding DefineScheduleVm}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="2"
                Background="{DynamicResource App.HeavyOverlayBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Loading..." 
                           Foreground="{DynamicResource App.TextPrimaryBrush}"
                           FontSize="14"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Toast Notifications -->
        <controls:ToastHostControl Grid.ColumnSpan="2"
                                   DataContext="{Binding ToastHost}"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Right"
                                   Panel.ZIndex="1000"/>

        <!-- Onboarding Overlay (first-run wizard) -->
        <Border Grid.ColumnSpan="2"
                Background="{DynamicResource App.OnboardingOverlayBrush}"
                Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="2000">
            <views:OnboardingView DataContext="{Binding OnboardingVm}"/>
        </Border>

        <!-- Initial Setup Wizard Overlay -->
        <Border Grid.ColumnSpan="2"
                Background="{DynamicResource App.OnboardingOverlayBrush}"
                Visibility="{Binding IsInitialSetupVisible, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="1900">
            <views:InitialSetupView DataContext="{Binding InitialSetupVm}"/>
        </Border>
    </Grid>
</UserControl>

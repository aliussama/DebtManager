            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Recurring}">
                <views:RecurringView DataContext="{Binding RecurringVm}"/>
            </Border>

            <!-- Import View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Import}">
                <views:ImportView DataContext="{Binding ImportVm}"/>
            </Border>

            <!-- Assets View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Assets2}">
                <views:AssetsView DataContext="{Binding AssetsVm}"/>
            </Border>

            <!-- Net Worth View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=NetWorth}">
                <views:NetWorthView DataContext="{Binding NetWorthVm}"/>
            </Border>

            <!-- Investment Accounts View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=InvestmentAccounts}">
                <views:InvestmentAccountsView DataContext="{Binding InvestmentAccountsVm}"/>
            </Border>

            <!-- Portfolio Investments View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=PortfolioInvestments}">
                <views:PortfolioView DataContext="{Binding PortfolioInvestmentsVm}"/>
            </Border>

            <!-- Taxes View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Taxes}">
                <views:TaxesView DataContext="{Binding TaxesVm}"/>
            </Border>

            <!-- Goals View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Goals}">
                <views:GoalsView DataContext="{Binding GoalsVm}"/>
            </Border>

            <!-- Retirement View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Retirement}">
                <views:RetirementView DataContext="{Binding RetirementVm}"/>
            </Border>

            <!-- Data Quality View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=DataQuality}">

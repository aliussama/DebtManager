            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Charges}">
                <views:ChargeBreakdownView DataContext="{Binding ChargeBreakdownVm}"/>
            </Border>

            <!-- Rule Pack Manager View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=RulePacks}">
                <views:RulePackManagerView DataContext="{Binding RulePackManagerVm}"/>
            </Border>

            <!-- Settings View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Settings}"
                    Background="{DynamicResource App.BackgroundBrush}">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </Border>

            <!-- Accounts View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Accounts}">
                <views:AccountsView DataContext="{Binding AccountsVm}"/>
            </Border>

            <!-- Cash Ledger View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=CashLedger}">
                <views:CashLedgerView DataContext="{Binding CashLedgerVm}"/>
            </Border>

            <!-- Categories View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Categories}">
                <views:CategoriesView DataContext="{Binding CategoriesVm}"/>
            </Border>

            <!-- Budgets View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Budgets}">
                <views:BudgetsView DataContext="{Binding BudgetsVm}"/>
            </Border>


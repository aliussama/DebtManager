            <!-- Forecast View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Forecast}">
                <views:ForecastView DataContext="{Binding ForecastVm}"/>
            </Border>

            <!-- Scenarios View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Scenarios}">
                <views:ScenariosView DataContext="{Binding ScenariosVm}"/>
            </Border>

            <!-- Parties View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Parties}">
                <views:PartiesView DataContext="{Binding PartiesVm}"/>
            </Border>

            <!-- Contracts View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Contracts}">
                <views:ContractsView DataContext="{Binding ContractsVm}"/>
            </Border>

            <!-- Bills View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Bills}">
                <views:BillsView DataContext="{Binding BillsVm}"/>
            </Border>

            <!-- Invoices View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Invoices}">
                <views:InvoicesView DataContext="{Binding InvoicesVm}"/>
            </Border>

            <!-- Notifications View -->
            <Border Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisibility}, ConverterParameter=Notifications}">
                <views:NotificationsView DataContext="{Binding NotificationsVm}"/>
            </Border>


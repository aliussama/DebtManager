<UserControl x:Class="DebtManager.Desktop.Views.TaxesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource App.BackgroundBrush}">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Taxes &amp; Year-End Reporting"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
            <TextBlock Text="Manage tax profiles, classification rules, and generate year-end reports."
                       FontSize="13" Foreground="{DynamicResource App.TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}">

            <!-- Profiles Tab -->
            <TabItem Header="Profiles">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Create Profile Form -->
                    <Border Grid.Row="0" Background="{DynamicResource App.SurfaceBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="New Tax Profile" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" Width="160" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Country" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewProfileCountryCode, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Start Month" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewProfileStartMonth, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Start Day" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewProfileStartDay, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Base Currency" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewProfileBaseCurrency, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Content="Create" Command="{Binding CreateProfileCommand}"
                                        Style="{StaticResource PrimaryButton}" Padding="16,6" Margin="0,14,0,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Profiles List -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="{DynamicResource App.SurfaceBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Country" Binding="{Binding CountryCode}" Width="60"/>
                            <DataGridTextColumn Header="Start" Binding="{Binding TaxYearStartMonth, StringFormat={}{0}/}" Width="50"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding BaseCurrencyCode}" Width="70"/>
                            <DataGridCheckBoxColumn Header="Archived" Binding="{Binding IsArchived}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="Archive Selected" Command="{Binding ArchiveProfileCommand}"
                            Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,0,-8" Padding="12,6"/>
                </Grid>
            </TabItem>

            <!-- Rules Tab -->
            <TabItem Header="Rules">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Define Rule Form -->
                    <Border Grid.Row="0" Background="{DynamicResource App.SurfaceBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="New Classification Rule" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Applies To" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <ComboBox Width="140" Margin="0,2,0,0"
                                              SelectedItem="{Binding NewRuleAppliesTo}">
                                        <ComboBoxItem Content="ExpenseCategory"/>
                                        <ComboBoxItem Content="IncomeSource"/>
                                        <ComboBoxItem Content="Symbol"/>
                                        <ComboBoxItem Content="TransactionType"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Match Value" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding NewRuleMatchValue, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,4">
                                    <TextBlock Text="Tax Category" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                    <ComboBox Width="150" Margin="0,2,0,0"
                                              SelectedItem="{Binding NewRuleTaxCategory}">
                                        <ComboBoxItem Content="DeductibleExpense"/>
                                        <ComboBoxItem Content="NonDeductible"/>
                                        <ComboBoxItem Content="DividendIncome"/>
                                        <ComboBoxItem Content="InterestIncome"/>
                                        <ComboBoxItem Content="CapitalGain"/>
                                        <ComboBoxItem Content="OtherIncome"/>
                                    </ComboBox>
                                </StackPanel>
                                <Button Content="Define Rule" Command="{Binding DefineRuleCommand}"
                                        Style="{StaticResource PrimaryButton}" Padding="16,6" Margin="0,14,0,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Rules List -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Rules}"
                              SelectedItem="{Binding SelectedRule}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="{DynamicResource App.SurfaceBrush}"
                              Foreground="{DynamicResource App.TextPrimaryBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Applies To" Binding="{Binding AppliesTo}" Width="120"/>
                            <DataGridTextColumn Header="Match Value" Binding="{Binding MatchValue}" Width="*"/>
                            <DataGridTextColumn Header="Tax Category" Binding="{Binding TaxCategory}" Width="140"/>
                            <DataGridCheckBoxColumn Header="Archived" Binding="{Binding IsArchived}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="Archive Selected" Command="{Binding ArchiveRuleCommand}"
                            Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,0,-8" Padding="12,6"/>
                </Grid>
            </TabItem>

            <!-- Year-End Report Tab -->
            <TabItem Header="Year-End Report">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Report Parameters -->
                    <Border Grid.Row="0" Background="{DynamicResource App.SurfaceBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <WrapPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Profile" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile}"
                                          DisplayMemberPath="Name"
                                          Width="200" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Tax Year" FontSize="11" Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ReportTaxYear, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Content="Generate Report" Command="{Binding GenerateReportCommand}"
                                    Style="{StaticResource PrimaryButton}" Padding="16,6" Margin="0,14,8,0"/>
                            <Button Content="Export CSV" Command="{Binding ExportReportCommand}"
                                    Padding="16,6" Margin="0,14,0,0"/>
                        </WrapPanel>
                    </Border>

                    <!-- Summary -->
                    <TextBlock Grid.Row="1" Text="{Binding ReportSummary}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.TextPrimaryBrush}"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <!-- Report Grids -->
                    <TabControl Grid.Row="2">
                        <TabItem Header="Capital Gains">
                            <DataGrid ItemsSource="{Binding CapitalGains}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Background="{DynamicResource App.SurfaceBrush}"
                                      Foreground="{DynamicResource App.TextPrimaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding TradeDate, StringFormat={}{0:yyyy-MM-dd}}" Width="90"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding QuantitySold}" Width="60"/>
                                    <DataGridTextColumn Header="Proceeds" Binding="{Binding Proceeds, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Cost Basis" Binding="{Binding CostBasis, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Gain" Binding="{Binding RealizedGain, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Days Held" Binding="{Binding HoldingPeriodDays}" Width="70"/>
                                    <DataGridTextColumn Header="Base Amt" Binding="{Binding AmountInBaseCurrency, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Income">
                            <DataGrid ItemsSource="{Binding IncomeLines}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Background="{DynamicResource App.SurfaceBrush}"
                                      Foreground="{DynamicResource App.TextPrimaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding IncomeType}" Width="120"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding SourceType}" Width="90"/>
                                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="90"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                                    <DataGridTextColumn Header="Base Amt" Binding="{Binding AmountInBaseCurrency, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Deductions">
                            <DataGrid ItemsSource="{Binding Deductions}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Background="{DynamicResource App.SurfaceBrush}"
                                      Foreground="{DynamicResource App.TextPrimaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="90"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                                    <DataGridTextColumn Header="Base Amt" Binding="{Binding AmountInBaseCurrency, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Unclassified">
                            <DataGrid ItemsSource="{Binding UnclassifiedItems}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False"
                                      Background="{DynamicResource App.SurfaceBrush}"
                                      Foreground="{DynamicResource App.TextPrimaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Source" Binding="{Binding SourceType}" Width="90"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="90"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="90"/>
                                    <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Background="{DynamicResource App.HeavyOverlayBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
